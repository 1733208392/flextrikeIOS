[sub_resource type="GDScript" id="GDScript_staff"]
script/source = "extends Control

const NOTE_Y_OFFSETS = {
	\"C3\": 60, \"D3\": 50, \"E3\": 40, \"F3\": 30, \"G3\": 20, \"A3\": 10, \"B3\": 0,
	\"C4\": -10, \"D4\": -20, \"E4\": -30, \"F4\": -40, \"G4\": -50, \"A4\": -60, \"B4\": -70
}

func _draw():
	var w = size.x
	var h = size.y
	var color = Color(0.87, 0.22, 0.14)
	var line_spacing = h / 6.0

	# Draw 5 lines of the staff
	for i in range(5):
		var y = (i + 1) * line_spacing
		draw_line(Vector2(0, y), Vector2(w, y), color, 2.0)

	var main_game = get_node_or_null(\"../..\")
	if not main_game or not \"collected_notes\" in main_game:
		return

	var notes = main_game.collected_notes
	var spacing = w / 9.0
	var center_y = 3 * line_spacing # Center line (B3/C4 area)

	for i in range(notes.size()):
		var note_name = notes[i]
		var x = (i + 1) * spacing
		
		# Calculate Y based on note pitch
		var y_offset = NOTE_Y_OFFSETS.get(note_name, 0)
		var y = center_y + y_offset
		
		# Draw Note Head
		draw_circle(Vector2(x, y), 8, color)
		# Draw Stem
		draw_line(Vector2(x + 7, y), Vector2(x + 7, y - 25), color, 3.0)
"

