{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .image-sequence-player-{{ ai_gen_id }} {
    position: relative;
    width: 100vw;
    height: 100vh;
    margin: 0 auto;
  }
  #sequence-canvas-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    display: block;
  }
  .chapter-overlay-{{ ai_gen_id }} {
    position: absolute;
    left: 40px;
    top: 50%;
    transform: translateY(-50%);
    z-index: 10;
    color: #ffffff;
    font-weight: 700;
    font-size: 48px;
    line-height: 1.2;
    max-width: 50%;
    text-shadow: 2px 2px 8px rgba(0, 0, 0, 0.7);
    font-family: 'TT Norms', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
    letter-spacing: -0.5px;
    pointer-events: none;
  }

  .chapter-overlay-{{ ai_gen_id }}.right {
    left: auto;
    right: 40px;
  }

  .chapter-overlay-{{ ai_gen_id }} > div:first-child {
    color: #DE3823;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .chapter-overlay-{{ ai_gen_id }} > div:nth-child(2),
  .chapter-overlay-{{ ai_gen_id }} > div:nth-child(3) {
    font-size: 16px;
    font-weight: 400;
    text-transform: none;
    letter-spacing: 0;
  }

  @media screen and (max-width: 1024px) {
    .chapter-overlay-{{ ai_gen_id }} {
      font-size: 36px;
      left: 30px;
    }

    .chapter-overlay-{{ ai_gen_id }}.right {
      left: auto;
      right: 30px;
    }

    .chapter-overlay-{{ ai_gen_id }} > div:first-child {
      font-size: 42px;
    }

    .chapter-overlay-{{ ai_gen_id }} > div:nth-child(2),
    .chapter-overlay-{{ ai_gen_id }} > div:nth-child(3) {
      font-size: 12px;
    }
  }

  @media screen and (max-width: 749px) {
    .chapter-overlay-{{ ai_gen_id }} {
      font-size: 24px;
      left: 20px;
      max-width: 70%;
    }

    .chapter-overlay-{{ ai_gen_id }}.right {
      left: auto;
      right: 20px;
    }

    .chapter-overlay-{{ ai_gen_id }} > div:first-child {
      font-size: 28px;
    }

    .chapter-overlay-{{ ai_gen_id }} > div:nth-child(2),
    .chapter-overlay-{{ ai_gen_id }} > div:nth-child(3) {
      font-size: 10px;
    }
  }
{% endstyle %}

<image-sequence-player-{{ ai_gen_id }}
  class="color-{{ block.settings.color_scheme }}"
  {{ block.shopify_attributes }}
>
  <div class="image-sequence-player-{{ ai_gen_id }}">
    <canvas id="sequence-canvas-{{ ai_gen_id }}" width="1920" height="1080"></canvas>
    <div class="chapter-overlay-{{ ai_gen_id }} chapter2-overlay-{{ ai_gen_id }} right" style="display:none;">
      <div>HIGH-IMPACT RESIST</div>
      <div>WITHSTANDS 100,000+ SHOTS AND EASILY REPLACEABLE</div>
    </div>
    <div class="chapter-overlay-{{ ai_gen_id }} chapter3-overlay-{{ ai_gen_id }}" style="display:none;">
      <div>MILLIMETER ACCURACY</div>
      <div>ACHIEVED BY PATENDED AI POWERED SONIC POSITIONING TECHNOLOGY</div>
    </div>
  </div>
</image-sequence-player-{{ ai_gen_id }}>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const players = document.querySelectorAll('image-sequence-player-{{ ai_gen_id }}');
    players.forEach(player => {
      const canvas = player.querySelector('#sequence-canvas-{{ ai_gen_id }}');
      const ctx = canvas.getContext('2d');

      const totalFrames = {{ block.settings.total_frames | default: 96 }};

      // URLs array generated by Liquid
      const urls = [{%- for i in (1..block.settings.total_frames) -%}{%- assign padded_i = i -%}{%- if i < 10 -%}{%- assign padded_i = '000' | append: padded_i -%}{%- elsif i < 100 -%}{%- assign padded_i = '00' | append: padded_i -%}{%- else -%}{%- assign padded_i = '0' | append: padded_i -%}{%- endif -%}"{{ padded_i | append: '.png' | asset_url }}"{%- if forloop.last == false -%},{%- endif -%}{%- endfor -%}];

      // Preload images
      const images = urls.map(url => {
        const img = new Image();
        img.src = url;
        return img;
      });

      const chapterFrames = "{{ block.settings.chapter_frames | default: '30,60,90' }}".split(',').map(f => parseInt(f.trim()) - 1);
      const chapter2Overlay = player.querySelector('.chapter2-overlay-{{ ai_gen_id }}');
      const chapter3Overlay = player.querySelector('.chapter3-overlay-{{ ai_gen_id }}');
      let currentChapter = 0;
      let currentFrame = 0;
      let isPlaying = true;
      let animationId;
      let lastFrameTime = Date.now();
      const frameDuration = 100;
      // Draw first frame
      drawFrame(0);

      function drawFrame(frame) {
        if (images[frame] && images[frame].complete) {
          canvas.width = canvas.offsetWidth;
          canvas.height = canvas.offsetHeight;
          const img = images[frame];
          const scaleX = canvas.width / img.width;
          const scaleY = canvas.height / img.height;
          const scale = Math.max(scaleX, scaleY);
          const scaledWidth = img.width * scale;
          const scaledHeight = img.height * scale;
          const x = (canvas.width - scaledWidth) / 2;
          const y = (canvas.height - scaledHeight) / 2;
          ctx.clearRect(0, 0, canvas.width, canvas.height);
          ctx.drawImage(img, x, y, scaledWidth, scaledHeight);
          const currentChap = getCurrentChapter(frame);
          chapter2Overlay.style.display = currentChap === 1 ? 'block' : 'none';
          chapter3Overlay.style.display = currentChap === 2 ? 'block' : 'none';
        }
      }

      function jumpToChapter(index) {
        if (index >= 0 && index < chapterFrames.length) {
          currentChapter = index;
          currentFrame = chapterFrames[index];
          drawFrame(currentFrame);
        }
      }

      function getCurrentChapter(frame) {
        for (let i = chapterFrames.length - 1; i >= 0; i--) {
          if (frame >= chapterFrames[i]) {
            return i;
          }
        }
        return 0;
      }

      function animate() {
        if (isPlaying) {
          const now = Date.now();
          if (now - lastFrameTime >= frameDuration) {
            drawFrame(currentFrame);
            currentFrame = (currentFrame + 1) % totalFrames;
            lastFrameTime = now;
          }
        }
        animationId = requestAnimationFrame(animate);
      }

      // Start animation
      animate();
    });
  });
</script>

{% schema %}
{
  "name": "Image Sequence Player",
  "tag": null,
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "scheme-1"
    },
    {
      "type": "number",
      "id": "total_frames",
      "label": "Total Frames",
      "default": 96
    },
    {
      "type": "text",
      "id": "chapter_frames",
      "label": "Chapter Frames",
      "default": "1,31,81"
    }
  ],
  "presets": [
    {
      "name": "Image Sequence Player"
    }
  ]
}
{% endschema %}