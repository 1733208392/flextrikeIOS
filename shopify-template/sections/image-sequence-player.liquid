{%- style -%}
  .image-sequence-player {
    position: relative;
    width: 100%;
    max-width: 800px;
    margin: 0 auto;
  }
  #sequence-canvas {
    width: 100%;
    height: auto;
    display: block;
    cursor: pointer;
  }
  .poi-button {
    position: absolute;
    width: 50px;
    height: 50px;
    background: rgba(255, 0, 0, 0.8);
    border: 2px solid white;
    border-radius: 50%;
    cursor: pointer;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    z-index: 10;
    display: none;
  }
  .poi-button:hover {
    background: rgba(255, 0, 0, 1);
  }
  .poi-text-display {
    position: absolute;
    background: rgba(0, 0, 0, 0.9);
    color: white;
    padding: 15px;
    border-radius: 5px;
    font-size: 16px;
    z-index: 15;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    max-width: 300px;
    text-align: center;
    display: none;
  }
{%- endstyle -%}

<div class="image-sequence-player">
  <canvas id="sequence-canvas" width="800" height="600"></canvas>
  <div class="poi-button" id="poi-button"></div>
  <div class="poi-text-display" id="poi-text">This is a test message</div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const canvas = document.getElementById('sequence-canvas');
    const ctx = canvas.getContext('2d');
    const poiButton = document.getElementById('poi-button');
    const poiText = document.getElementById('poi-text');

    const totalFrames = {{ section.settings.total_frames | default: 40 }};
    const framePrefix = '{{ section.settings.frame_prefix | default: "frame_" }}';

    // URLs array generated by Liquid
    const urls = [{%- for i in (1..section.settings.total_frames) -%}{%- assign padded_i = i -%}{%- if i < 10 -%}{%- assign padded_i = '000' | append: padded_i -%}{%- elsif i < 100 -%}{%- assign padded_i = '00' | append: padded_i -%}{%- else -%}{%- assign padded_i = '0' | append: padded_i -%}{%- endif -%}"{{ section.settings.frame_prefix | default: 'frame_' | append: padded_i | append: '.png' | asset_url }}"{%- if forloop.last == false -%},{%- endif -%}{%- endfor -%}];

    // Preload images
    const images = urls.map(url => {
      const img = new Image();
      img.src = url;
      return img;
    });

    // Draw first frame
    drawFrame(0);

    let currentFrame = 0;
    let isPlaying = true; // Auto-play
    let animationId;
    let lastFrameTime = Date.now();
    const frameDuration = 100; // Milliseconds per frame (100ms = slower motion)
    
    function drawFrame(frame) {
      if (images[frame] && images[frame].complete) {
        ctx.clearRect(0, 0, canvas.width, canvas.height);
        ctx.drawImage(images[frame], 0, 0, canvas.width, canvas.height);
      }
    }

    // Animation loop
    function animate() {
      if (isPlaying) {
        const now = Date.now();
        if (now - lastFrameTime >= frameDuration) {
          drawFrame(currentFrame);
          currentFrame = (currentFrame + 1) % totalFrames;
          lastFrameTime = now;
        }
      }
      animationId = requestAnimationFrame(animate);
    }

    // Stop playing and jump to frame 0 when mouse enters
    canvas.addEventListener('mouseenter', function() {
      isPlaying = false;
      currentFrame = 0;
      drawFrame(0);
      poiButton.style.display = 'block'; // Show POI
      poiText.style.display = 'none'; // Hide text
    });

    // Resume playing when mouse leaves the canvas
    canvas.addEventListener('mouseleave', function() {
      isPlaying = true;
      lastFrameTime = Date.now();
      poiButton.style.display = 'none'; // Hide POI
      poiText.style.display = 'none'; // Hide text
    });

    // POI button click to show text
    poiButton.addEventListener('click', function(e) {
      e.stopPropagation(); // Prevent triggering canvas mouseenter
      poiText.style.display = 'block';
      setTimeout(() => {
        poiText.style.display = 'none';
      }, 3000); // Hide text after 3 seconds
    });

    // Stop propagation when text is clicked
    poiText.addEventListener('click', function(e) {
      e.stopPropagation();
    });

    // Start animation
    animate();
  });
</script>

{% schema %}
{
  "name": "Image Sequence Player",
  "settings": [
    {
      "type": "text",
      "id": "frame_prefix",
      "label": "Frame Prefix",
      "default": "frame_"
    },
    {
      "type": "number",
      "id": "total_frames",
      "label": "Total Frames",
      "default": 40
    }
  ]
}
{% endschema %}