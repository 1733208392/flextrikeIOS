    "landing_faq": {
      "type": "faq-flextarget",
      "blocks": {
        "lf_1":  { "type": "faq_item", "settings": { "heading": "Do I need a real firearm to use FlexTarget?", "answer": "<p>No. FlexTarget works with airsoft BBs. It's designed for both airsoft replicas and dry fire practice. No real ammunition needed.</p>" } },
        "lf_2":  { "type": "faq_item", "settings": { "heading": "Is it loud? Can I use it in an apartment?", "answer": "<p>Yes! FlexTarget uses airsoft BBs (under 400 FPS with 0.2g BBs), which are much quieter than live fire. You can safely use it in your garage, basement, or even a spare room.</p>" } },
        "lf_3":  { "type": "faq_item", "settings": { "heading": "What's included in the box?", "answer": "<p>Everything you need to start training: the FlexTarget electronic screen system, mounting hardware, power supply, and free access to the FlexTarget App. Airsoft replica not included.</p>" } },
        "lf_4":  { "type": "faq_item", "settings": { "heading": "Does the App require a subscription?", "answer": "<p>No. The FlexTarget App is free to download and includes 1 year of data storage. No monthly fees, no hidden costs.</p>" } },
        "lf_5":  { "type": "faq_item", "settings": { "heading": "How does the tracking technology work?", "answer": "<p>FlexTarget uses smart sensor technology to detect BB impacts with millisecond precision. It tracks hit rates, split times, reaction speed, and more — all synced wirelessly to the App.</p>" } },
        "lf_6":  { "type": "faq_item", "settings": { "heading": "What training drills are available?", "answer": "<p>Unlimited! Including Free Shooting on 10+ target types, Custom Drills, Dynamic Stress Drills, and TargetLink Stages. You can also design your own drills in the App.</p>" } },
        "lf_7":  { "type": "faq_item", "settings": { "heading": "What's the shooting distance?", "answer": "<p>The optimal shooting distance is 4m to 10m (13–32 feet). The system supports split times as fast as 0.05 seconds.</p>" } },
        "lf_8":  { "type": "faq_item", "settings": { "heading": "How much will I save compared to live fire?", "answer": "<p>A lot. Live fire training costs approximately $4,800+ per year (ammo + range fees). FlexTarget is a one-time purchase of $299–439 + about $50/year in BBs. It pays for itself in less than 2 range trips.</p>" } },
        "lf_9":  { "type": "faq_item", "settings": { "heading": "What's your return policy?", "answer": "<p>We offer a 30-day money-back guarantee. If you're not satisfied with your FlexTarget, return it within 30 days for a full refund. Free shipping on all US orders.</p>" } },
        "lf_10": { "type": "faq_item", "settings": { "heading": "Do you ship internationally?", "answer": "<p>Yes, we ship worldwide. Free shipping on all US orders. International shipping rates and delivery times vary by destination.</p>" } }
      },
