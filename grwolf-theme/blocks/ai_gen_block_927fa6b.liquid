{% doc %}
  @prompt
    Create a comparison table section with the following content and styling:
    
    Table title: Training Method Comparison
    
    Columns: Feature | Live Fire Training | Dry Fire (No Feedback) | GRWOLF FlexTarget System
    
    Rows:
    - Cost Per 1,000 Rounds | ~$400 (9mm) / ~$550 (5.56) | $0.00 | <$5.00 (High-Grade BBs)
    - Location | Dedicated Range Only | Anywhere | Your Garage, Basement, or Yard
    - Data Tracking | Manual / Shot Timer Only | None | Instant App-Based Analytics
    - Projectile Feedback | Yes | No | Yes (Active Target Reaction)
    - Reaction Drills | Limited by Range Rules | No | Dynamic "Stress" Modes
    - Total 1-Year Cost* | $4,800+ | $0 | $399 (One-time) + $50 (Ammo)
    
    Footer note: *Based on a modest 1,000 rounds per month training schedule.
    
    The GRWOLF FlexTarget System column should be visually highlighted to stand out (e.g., different background color or bold header). The table should be responsive and look clean and professional, fitting a tactical/training brand aesthetic.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-comparison-table-{{ ai_gen_id }} {
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    display: block;
    padding: {{ block.settings.section_padding }}px 20px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-comparison-table__title-{{ ai_gen_id }} {
    text-align: {{ block.settings.title_alignment }};
    font-size: {{ block.settings.title_size }}px;
    color: {{ block.settings.title_color }};
    margin: 0 0 {{ block.settings.title_spacing }}px;
    font-weight: 700;
  }

  .ai-comparison-table__subtitle-{{ ai_gen_id }} {
    text-align: {{ block.settings.title_alignment }};
    font-size: {{ block.settings.title_size | times: 0.7 }}px;
    color: {{ block.settings.title_color }};
    margin: 0 0 {{ block.settings.title_spacing | times: 0.3 }}px;
    font-weight: 400;
  }

  .ai-comparison-table__wrapper-{{ ai_gen_id }} {
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
  }

  .ai-comparison-table__table-{{ ai_gen_id }} {
    width: 100%;
    border-collapse: collapse;
    background-color: {{ block.settings.table_background }};
    border-radius: {{ block.settings.table_border_radius }}px;
    overflow: hidden;
  }

  .ai-comparison-table__table-{{ ai_gen_id }} th,
  .ai-comparison-table__table-{{ ai_gen_id }} td {
    padding: {{ block.settings.cell_padding }}px;
    text-align: left;
    border-bottom: {{ block.settings.border_thickness }}px solid {{ block.settings.border_color }};
  }

  .ai-comparison-table__table-{{ ai_gen_id }} thead th {
    background-color: {{ block.settings.header_background }};
    color: {{ block.settings.header_text_color }};
    font-weight: 700;
    font-size: {{ block.settings.header_font_size }}px;
    text-align: center;
    vertical-align: middle;
  }

  .ai-comparison-table__table-{{ ai_gen_id }} thead th:first-child {
    text-align: left;
  }

  .ai-comparison-table__table-{{ ai_gen_id }} tbody th {
    background-color: {{ block.settings.row_header_background }};
    color: {{ block.settings.row_header_text_color }};
    font-weight: 600;
    font-size: {{ block.settings.body_font_size }}px;
  }

  .ai-comparison-table__table-{{ ai_gen_id }} tbody td {
    background-color: {{ block.settings.cell_background }};
    color: {{ block.settings.cell_text_color }};
    font-size: {{ block.settings.body_font_size }}px;
    text-align: center;
    vertical-align: middle;
  }

  .ai-comparison-table__highlighted-{{ ai_gen_id }} {
    background-color: {{ block.settings.highlight_background }} !important;
    color: {{ block.settings.highlight_text_color }} !important;
    font-weight: 700;
    position: relative;
  }

  .ai-comparison-table__highlighted-{{ ai_gen_id }}::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background-color: {{ block.settings.highlight_accent_color }};
  }

  .ai-comparison-table__footer-{{ ai_gen_id }} {
    margin-top: {{ block.settings.footer_spacing }}px;
    padding: {{ block.settings.footer_padding }}px;
    background-color: {{ block.settings.footer_background }};
    border-radius: {{ block.settings.footer_border_radius }}px;
    color: {{ block.settings.footer_text_color }};
    font-size: {{ block.settings.footer_font_size }}px;
    font-style: italic;
  }

  @media screen and (max-width: 749px) {
    .ai-comparison-table__table-{{ ai_gen_id }} th,
    .ai-comparison-table__table-{{ ai_gen_id }} td {
      padding: {{ block.settings.cell_padding | times: 0.7 }}px;
      font-size: {{ block.settings.body_font_size | times: 0.9 }}px;
    }

    .ai-comparison-table__table-{{ ai_gen_id }} thead th {
      font-size: {{ block.settings.header_font_size | times: 0.9 }}px;
    }

    .ai-comparison-table__title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_size | times: 0.8 }}px;
    }

    .ai-comparison-table__subtitle-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_size | times: 0.7 | times: 0.8 }}px;
    }
  }
{% endstyle %}

<comparison-table-{{ ai_gen_id }}
  class="ai-comparison-table-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  {% if block.settings.table_title != blank %}
    <h2 class="ai-comparison-table__title-{{ ai_gen_id }}">{{ block.settings.table_title }}</h2>
    <p class="ai-comparison-table__subtitle-{{ ai_gen_id }}">The FlexTarget pays for itself in less than two range trips.</p>
  {% endif %}

  <div class="ai-comparison-table__wrapper-{{ ai_gen_id }}">
    <table class="ai-comparison-table__table-{{ ai_gen_id }}">
      <thead>
        <tr>
          <th>{{ block.settings.column_1_header }}</th>
          <th>{{ block.settings.column_2_header }}</th>
          <th>{{ block.settings.column_3_header }}</th>
          <th class="ai-comparison-table__highlighted-{{ ai_gen_id }}">{{ block.settings.column_4_header }}</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <th>{{ block.settings.row_1_label }}</th>
          <td>{{ block.settings.row_1_col_2 }}</td>
          <td>{{ block.settings.row_1_col_3 }}</td>
          <td class="ai-comparison-table__highlighted-{{ ai_gen_id }}">{{ block.settings.row_1_col_4 }}</td>
        </tr>
        <tr>
          <th>{{ block.settings.row_2_label }}</th>
          <td>{{ block.settings.row_2_col_2 }}</td>
          <td>{{ block.settings.row_2_col_3 }}</td>
          <td class="ai-comparison-table__highlighted-{{ ai_gen_id }}">{{ block.settings.row_2_col_4 }}</td>
        </tr>
        <tr>
          <th>{{ block.settings.row_3_label }}</th>
          <td>{{ block.settings.row_3_col_2 }}</td>
          <td>{{ block.settings.row_3_col_3 }}</td>
          <td class="ai-comparison-table__highlighted-{{ ai_gen_id }}">{{ block.settings.row_3_col_4 }}</td>
        </tr>
        <tr>
          <th>{{ block.settings.row_4_label }}</th>
          <td>{{ block.settings.row_4_col_2 }}</td>
          <td>{{ block.settings.row_4_col_3 }}</td>
          <td class="ai-comparison-table__highlighted-{{ ai_gen_id }}">{{ block.settings.row_4_col_4 }}</td>
        </tr>
        <tr>
          <th>{{ block.settings.row_5_label }}</th>
          <td>{{ block.settings.row_5_col_2 }}</td>
          <td>{{ block.settings.row_5_col_3 }}</td>
          <td class="ai-comparison-table__highlighted-{{ ai_gen_id }}">{{ block.settings.row_5_col_4 }}</td>
        </tr>
        <tr>
          <th>{{ block.settings.row_6_label }}</th>
          <td>{{ block.settings.row_6_col_2 }}</td>
          <td>{{ block.settings.row_6_col_3 }}</td>
          <td class="ai-comparison-table__highlighted-{{ ai_gen_id }}">{{ block.settings.row_6_col_4 }}</td>
        </tr>
      </tbody>
    </table>
  </div>

  {% if block.settings.footer_note != blank %}
    <div class="ai-comparison-table__footer-{{ ai_gen_id }}">
      {{ block.settings.footer_note }}
    </div>
  {% endif %}
</comparison-table-{{ ai_gen_id }}>

<script>
  (function() {
    class ComparisonTable{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.setupAccessibility();
      }

      setupAccessibility() {
        const table = this.querySelector('.ai-comparison-table__table-{{ ai_gen_id }}');
        if (table) {
          table.setAttribute('role', 'table');
          table.setAttribute('aria-label', 'Training method comparison table');
        }
      }
    }

    customElements.define('comparison-table-{{ ai_gen_id }}', ComparisonTable{{ ai_gen_id }});
  })();
</script>

