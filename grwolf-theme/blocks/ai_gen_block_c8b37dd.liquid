{% doc %}
  @prompt
    Create a video section that autoplays and is muted by default. The video should support both Shopify-hosted video files and YouTube/Vimeo URLs. Include settings for video source, cover image, enable/disable looping, full width toggle, and color scheme options.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-video-section-{{ ai_gen_id }} {
    display: block;
    position: relative;
    width: 100%;
    {% if block.settings.full_width %}
      margin: 0;
      padding: 0;
    {% else %}
      max-width: {{ settings.page_width }}px;
      margin: 0 auto;
      padding: 0 20px;
    {% endif %}
  }

  .ai-video-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    overflow: hidden;
    background-color: #000000;
    border-radius: {{ settings.media_radius }}px;
  }

  .ai-video-container-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    padding-bottom: 56.25%;
    height: 0;
    overflow: hidden;
  }

  .ai-video-container-{{ ai_gen_id }} video,
  .ai-video-container-{{ ai_gen_id }} iframe {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 1;
  }

  .ai-video-cover-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 1;
    transition: opacity 0.3s ease;
  }

  .ai-video-cover-{{ ai_gen_id }}.hidden {
    opacity: 0;
    pointer-events: none;
  }

  .ai-video-play-button-{{ ai_gen_id }} {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    z-index: 2;
    width: 80px;
    height: 80px;
    background-color: rgba(255, 255, 255, 0.9);
    border: none;
    border-radius: 50%;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.3s ease;
  }

  .ai-video-play-button-{{ ai_gen_id }}:hover {
    background-color: rgba(255, 255, 255, 1);
    transform: translate(-50%, -50%) scale(1.1);
  }

  .ai-video-play-button-{{ ai_gen_id }}.hidden {
    opacity: 0;
    pointer-events: none;
  }

  .ai-video-play-button-{{ ai_gen_id }} svg {
    width: 32px;
    height: 32px;
    margin-left: 4px;
  }

  .ai-video-placeholder-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    padding-bottom: 56.25%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-video-placeholder-{{ ai_gen_id }} svg {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 100%;
    height: 100%;
    max-width: 500px;
    max-height: 500px;
  }

  .ai-video-empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }

  .ai-video-controls-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    right: 20px;
    z-index: 3;
    display: flex;
    gap: 10px;
  }

  .ai-video-control-button-{{ ai_gen_id }} {
    width: 40px;
    height: 40px;
    background-color: rgba(0, 0, 0, 0.6);
    border: none;
    border-radius: 50%;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background-color 0.3s ease;
    color: #ffffff;
  }

  .ai-video-control-button-{{ ai_gen_id }}:hover {
    background-color: rgba(0, 0, 0, 0.8);
  }

  .ai-video-control-button-{{ ai_gen_id }} svg {
    width: 20px;
    height: 20px;
  }

  .ai-video-text-overlay-{{ ai_gen_id }} {
    position: absolute;
    left: 40px;
    top: 50%;
    transform: translateY(-50%);
    z-index: 4;
    color: #ffffff;
    font-weight: 700;
    font-size: 48px;
    line-height: 1.2;
    max-width: 50%;
    text-shadow: 2px 2px 8px rgba(0, 0, 0, 0.7);
    font-family: 'TT Norms', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
    letter-spacing: -0.5px;
  }

  .ai-video-text-overlay-{{ ai_gen_id }} > div:first-child {
    color: #DE3823;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  @media screen and (max-width: 1024px) {
    .ai-video-text-overlay-{{ ai_gen_id }} {
      font-size: 36px;
      left: 30px;
    }

    .ai-video-text-overlay-{{ ai_gen_id }} > div:first-child {
      font-size: 42px;
    }
  }

  .ai-video-text-overlay-right-{{ ai_gen_id }} {
    position: absolute;
    left: 66.67%;
    top: 50%;
    transform: translateY(-50%);
    z-index: 4;
    color: #ffffff;
    font-weight: 700;
    font-size: 48px;
    line-height: 1.2;
    max-width: 50%;
    text-shadow: 2px 2px 8px rgba(0, 0, 0, 0.7);
    font-family: 'TT Norms', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
    letter-spacing: -0.5px;
    transition: opacity 0.3s ease;
  }

  .ai-video-text-overlay-right-{{ ai_gen_id }} > div:first-child {
    color: #DE3823;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .ai-video-text-overlay-right-{{ ai_gen_id }}.hidden {
    opacity: 0;
    pointer-events: none;
  }

  .ai-video-text-overlay-third-{{ ai_gen_id }} {
    position: absolute;
    left: 40px;
    top: 50%;
    transform: translateY(-50%);
    z-index: 4;
    color: #ffffff;
    font-weight: 700;
    font-size: 48px;
    line-height: 1.2;
    max-width: 50%;
    text-shadow: 2px 2px 8px rgba(0, 0, 0, 0.7);
    font-family: 'TT Norms', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
    letter-spacing: -0.5px;
    transition: opacity 0.3s ease;
  }

  .ai-video-text-overlay-third-{{ ai_gen_id }} > div:first-child {
    color: #DE3823;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .ai-video-text-overlay-third-{{ ai_gen_id }}.hidden {
    opacity: 0;
    pointer-events: none;
  }

  @media screen and (max-width: 1024px) {
    .ai-video-text-overlay-third-{{ ai_gen_id }} {
      font-size: 36px;
      left: 30px;
    }

    .ai-video-text-overlay-third-{{ ai_gen_id }} > div:first-child {
      font-size: 42px;
    }
  }

  @media screen and (max-width: 749px) {
    .ai-video-text-overlay-third-{{ ai_gen_id }} {
      font-size: 18px;
      left: 20px;
      max-width: 70%;
    }

    .ai-video-text-overlay-third-{{ ai_gen_id }} > div:first-child {
      font-size: 24px;
    }
  }

  @media screen and (max-width: 1024px) {
    .ai-video-text-overlay-right-{{ ai_gen_id }} {
      font-size: 36px;
      left: 66.67%;
    }

    .ai-video-text-overlay-right-{{ ai_gen_id }} > div:first-child {
      font-size: 42px;
    }
  }

  @media screen and (max-width: 749px) {
    .ai-video-text-overlay-right-{{ ai_gen_id }} {
      font-size: 18px;
      left: 66.67%;
      max-width: 70%;
    }

    .ai-video-text-overlay-right-{{ ai_gen_id }} > div:first-child {
      font-size: 24px;
    }
  }

  @media screen and (max-width: 749px) {
    .ai-video-play-button-{{ ai_gen_id }} {
      width: 60px;
      height: 60px;
    }

    .ai-video-play-button-{{ ai_gen_id }} svg {
      width: 24px;
      height: 24px;
    }

    .ai-video-controls-{{ ai_gen_id }} {
      bottom: 10px;
      right: 10px;
    }

    .ai-video-control-button-{{ ai_gen_id }} {
      width: 36px;
      height: 36px;
    }

    .ai-video-text-overlay-{{ ai_gen_id }} {
      font-size: 18px;
      left: 20px;
      max-width: 70%;
    }

    .ai-video-text-overlay-{{ ai_gen_id }} > div:first-child {
      font-size: 24px;
    }

    .ai-video-image-button-{{ ai_gen_id }} {
      width: 40vw;
      height: 40vw;
      max-width: 80%;
      max-height: 80%;
      right: 5%;
    }
  }

  @media screen and (max-width: 480px) {
    .ai-video-image-button-{{ ai_gen_id }} {
      width: 28vw;
      height: 28vw;
      max-width: 60%;
      max-height: 60%;
      right: 10%;
    }
  }

  /* Safari-specific fixes for mobile */
  @supports (-webkit-touch-callout: none) {
    .ai-video-image-button-{{ ai_gen_id }} {
      width: 35vw;
      height: 35vw;
      max-width: 50%;
      max-height: 50%;
      right: 15%;
    }
    
    @media screen and (max-width: 480px) {
      .ai-video-image-button-{{ ai_gen_id }} {
        width: 22vw;
        height: 22vw;
        max-width: 45%;
        max-height: 45%;
        right: 13%;
      }
    }
  }

  .ai-video-image-button-{{ ai_gen_id }} {
    position: absolute;
    right: 10%;
    top: 50%;
    transform: translateY(-50%);
    width: 40vw;
    height: 40vw;
    max-width: 50%;
    max-height: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    z-index: 10;
    border: none;
    background: none;
    padding: 0;
  }

  .ai-video-image-button-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    opacity: 0.7;
    transition: opacity 0.3s ease, filter 0.3s ease;
  }

  .ai-video-image-button-{{ ai_gen_id }}.hidden {
    display: none !important;
  }

  .ai-video-image-button-{{ ai_gen_id }}:hover img {
    opacity: 1;
    filter: drop-shadow(0 0 20px rgba(255, 255, 255, 0.8)) drop-shadow(0 0 10px rgba(255, 255, 255, 0.6));
  }
{% endstyle %}

<video-player-{{ ai_gen_id }}
  class="ai-video-section-{{ ai_gen_id }} color-{{ block.settings.color_scheme }}"
  data-video-type="{{ block.settings.video_source }}"
  data-autoplay="true"
  data-loop="{{ block.settings.enable_loop }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-video-wrapper-{{ ai_gen_id }}">
    <div class="ai-video-text-overlay-{{ ai_gen_id }}">
      <div>GRWOLF FLEXTARGET</div>
      <div>Train Smarter</div>
      <div>Shoot Sharper</div>
      <div>Dominate Faster</div>
    </div>
    <div class="ai-video-text-overlay-right-{{ ai_gen_id }} hidden">
      <div>{{ block.settings.right_overlay_line1 }}</div>
      <div>{{ block.settings.right_overlay_line2 }}</div>
      <div>{{ block.settings.right_overlay_line3 }}</div>
      <div>{{ block.settings.right_overlay_line4 }}</div>
    </div>
    <div class="ai-video-text-overlay-third-{{ ai_gen_id }} hidden">
      <div>{{ block.settings.third_overlay_line1 }}</div>
      <div>{{ block.settings.third_overlay_line2 }}</div>
      <div>{{ block.settings.third_overlay_line3 }}</div>
      <div>{{ block.settings.third_overlay_line4 }}</div>
    </div>
    {%- if block.settings.button_image != blank -%}
      <button 
        class="ai-video-image-button-{{ ai_gen_id }}" 
        aria-label="Interactive button" 
        type="button"
        data-button-video-type="{{ block.settings.button_video_source }}"
        {% if block.settings.button_video_source == 'shopify' and block.settings.button_video_shopify != blank %}
          data-button-video-url="{{ block.settings.button_video_shopify.sources[1].url }}"
          data-button-video-type-mime="{{ block.settings.button_video_shopify.sources[1].mime_type }}"
        {% elsif block.settings.button_video_source == 'youtube' and block.settings.button_video_url != blank %}
          data-button-video-id="{{ block.settings.button_video_url | split: 'v=' | last | split: '&' | first }}"
        {% elsif block.settings.button_video_source == 'vimeo' and block.settings.button_video_url != blank %}
          data-button-video-id="{{ block.settings.button_video_url | split: 'vimeo.com/' | last | split: '?' | first }}"
        {% endif %}
      >
        {{
          block.settings.button_image
          | image_url: width: 800
          | image_tag: alt: block.settings.button_image.alt
        }}
      </button>
    {%- endif -%}
    {% if block.settings.video_source == 'shopify' and block.settings.video_shopify != blank %}
      <div class="ai-video-container-{{ ai_gen_id }}">
        <video
          class="ai-video-element-{{ ai_gen_id }}"
          {% if block.settings.enable_loop %}loop{% endif %}
          muted
          playsinline
          preload="metadata"
        >
          <source src="{{ block.settings.video_shopify.sources[1].url }}" type="{{ block.settings.video_shopify.sources[1].mime_type }}">
        </video>

        {% if block.settings.cover_image %}
          <img
            src="{{ block.settings.cover_image | image_url: width: 1920 }}"
            alt="{{ block.settings.cover_image.alt | escape }}"
            class="ai-video-cover-{{ ai_gen_id }}"
            loading="lazy"
            width="{{ block.settings.cover_image.width }}"
            height="{{ block.settings.cover_image.height }}"
          >
        {% endif %}

        <button
          class="ai-video-play-button-{{ ai_gen_id }}"
          aria-label="Play video"
        >
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
            <path d="M8 5v14l11-7z"/>
          </svg>
        </button>

        <div class="ai-video-controls-{{ ai_gen_id }}">
          <button
            class="ai-video-control-button-{{ ai_gen_id }} ai-video-mute-button-{{ ai_gen_id }}"
            aria-label="Unmute video"
          >
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"></polygon>
              <line x1="23" y1="9" x2="17" y2="15"></line>
              <line x1="17" y1="9" x2="23" y2="15"></line>
            </svg>
          </button>
        </div>
      </div>

    {% elsif block.settings.video_source == 'youtube' and block.settings.video_url != blank %}
      {% assign video_id = block.settings.video_url | split: 'v=' | last | split: '&' | first %}
      {% if video_id == block.settings.video_url %}
        {% assign video_id = block.settings.video_url | split: 'youtu.be/' | last | split: '?' | first %}
      {% endif %}

      <div class="ai-video-container-{{ ai_gen_id }}">
        <div id="ai-youtube-player-{{ ai_gen_id }}" data-video-id="{{ video_id }}"></div>

        {% if block.settings.cover_image %}
          <img
            src="{{ block.settings.cover_image | image_url: width: 1920 }}"
            alt="{{ block.settings.cover_image.alt | escape }}"
            class="ai-video-cover-{{ ai_gen_id }}"
            loading="lazy"
            width="{{ block.settings.cover_image.width }}"
            height="{{ block.settings.cover_image.height }}"
          >
        {% endif %}

        <button
          class="ai-video-play-button-{{ ai_gen_id }}"
          aria-label="Play video"
        >
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
            <path d="M8 5v14l11-7z"/>
          </svg>
        </button>
      </div>

    {% elsif block.settings.video_source == 'vimeo' and block.settings.video_url != blank %}
      {% assign video_id = block.settings.video_url | split: 'vimeo.com/' | last | split: '?' | first %}

      <div class="ai-video-container-{{ ai_gen_id }}">
        <iframe
          id="ai-vimeo-player-{{ ai_gen_id }}"
          src="https://player.vimeo.com/video/{{ video_id }}?autoplay=1&muted=1&loop={{ block.settings.enable_loop }}&background=1"
          frameborder="0"
          allow="autoplay; fullscreen; picture-in-picture"
          allowfullscreen
        ></iframe>

        {% if block.settings.cover_image %}
          <img
            src="{{ block.settings.cover_image | image_url: width: 1920 }}"
            alt="{{ block.settings.cover_image.alt | escape }}"
            class="ai-video-cover-{{ ai_gen_id }}"
            loading="lazy"
            width="{{ block.settings.cover_image.width }}"
            height="{{ block.settings.cover_image.height }}"
          >
        {% endif %}

        <button
          class="ai-video-play-button-{{ ai_gen_id }}"
          aria-label="Play video"
        >
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
            <path d="M8 5v14l11-7z"/>
          </svg>
        </button>
      </div>

    {% else %}
      <div class="ai-video-placeholder-{{ ai_gen_id }}">
        {{ 'hero-apparel-1' | placeholder_svg_tag }}
        <div class="ai-video-empty-state-{{ ai_gen_id }}">
          Next, add a video or video URL
        </div>
      </div>
    {% endif %}
  </div>
</video-player-{{ ai_gen_id }}>

<script>
  (function() {
    class VideoPlayer{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.videoType = this.dataset.videoType;
        this.autoplay = this.dataset.autoplay === 'true';
        this.loop = this.dataset.loop === 'true';
        this.isPlaying = false;
        this.isMuted = true;
      }

      connectedCallback() {
        this.videoElement = this.querySelector('.ai-video-element-{{ ai_gen_id }}');
        this.playButton = this.querySelector('.ai-video-play-button-{{ ai_gen_id }}');
        this.muteButton = this.querySelector('.ai-video-mute-button-{{ ai_gen_id }}');
        this.coverImage = this.querySelector('.ai-video-cover-{{ ai_gen_id }}');
        this.imageButton = this.querySelector('.ai-video-image-button-{{ ai_gen_id }}')
        this.leftOverlay = this.querySelector('.ai-video-text-overlay-{{ ai_gen_id }}');
        this.rightOverlay = this.querySelector('.ai-video-text-overlay-right-{{ ai_gen_id }}');
        this.thirdOverlay = this.querySelector('.ai-video-text-overlay-third-{{ ai_gen_id }}');
        this.isPlayingButtonVideo = false;
        this.autoLoopMode = false;
        this.userInteracted = false;

        // Setup image button click handler
        if (this.imageButton) {
          this.imageButton.addEventListener('click', () => {
            this.userInteracted = true;
            this.autoLoopMode = false;
            this.loadButtonVideo();
          });
        }

        if (this.videoType === 'shopify' && this.videoElement) {
          this.setupShopifyVideo();
        } else if (this.videoType === 'youtube') {
          this.setupYouTubeVideo();
        } else if (this.videoType === 'vimeo') {
          this.setupVimeoVideo();
        }
      }

      setupShopifyVideo() {
        if (this.playButton) {
          this.playButton.addEventListener('click', () => {
            this.playVideo();
          });
        }

        if (this.muteButton) {
          this.muteButton.addEventListener('click', () => {
            this.toggleMute();
          });
        }

        if (this.autoplay) {
          this.videoElement.addEventListener('loadedmetadata', () => {
            this.playVideo();
          });
        }

        this.videoElement.addEventListener('play', () => {
          this.isPlaying = true;
        });

        this.videoElement.addEventListener('pause', () => {
          this.isPlaying = false;
        });

        // Auto-play button video when main video ends
        this.videoElement.addEventListener('ended', () => {
          if (!this.isPlayingButtonVideo && !this.userInteracted && this.imageButton?.dataset.buttonVideoType) {
            this.autoLoopMode = true;
            setTimeout(() => {
              this.loadButtonVideo();
            }, 300);
          }
        });
      }

      setupYouTubeVideo() {
        const playerElement = this.querySelector('#ai-youtube-player-{{ ai_gen_id }}');
        if (!playerElement) return;

        const videoId = playerElement.dataset.videoId;

        if (!window.YT) {
          const tag = document.createElement('script');
          tag.src = 'https://www.youtube.com/iframe_api';
          const firstScriptTag = document.getElementsByTagName('script')[0];
          firstScriptTag.parentNode.insertBefore(tag, firstScriptTag);
        }

        const initPlayer = () => {
          this.youtubePlayer = new YT.Player('ai-youtube-player-{{ ai_gen_id }}', {
            videoId: videoId,
            playerVars: {
              autoplay: 0,
              mute: 1,
              loop: this.loop ? 1 : 0,
              playlist: this.loop ? videoId : '',
              controls: 1,
              modestbranding: 1,
              rel: 0
            },
            events: {
              onReady: (event) => {
                if (this.playButton) {
                  this.playButton.addEventListener('click', () => {
                    event.target.playVideo();
                    this.hideCoverAndButton();
                  });
                }
              }
            }
          });
        };

        if (window.YT && window.YT.Player) {
          initPlayer();
        } else {
          window.onYouTubeIframeAPIReady = initPlayer;
        }
      }

      setupVimeoVideo() {
        if (this.playButton) {
          this.playButton.addEventListener('click', () => {
            this.hideCoverAndButton();
          });
        }

        setTimeout(() => {
          this.hideCoverAndButton();
        }, 100);
      }

      playVideo() {
        if (this.videoElement) {
          this.videoElement.play();
          this.hideCoverAndButton();
        }
      }

      toggleMute() {
        if (this.videoElement) {
          this.isMuted = !this.isMuted;
          this.videoElement.muted = this.isMuted;
          this.updateMuteButton();
        }
      }

      updateMuteButton() {
        if (!this.muteButton) return;

        const svg = this.isMuted
          ? '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"></polygon><line x1="23" y1="9" x2="17" y2="15"></line><line x1="17" y1="9" x2="23" y2="15"></line></svg>'
          : '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"></polygon><path d="M19.07 4.93a10 10 0 0 1 0 14.14M15.54 8.46a5 5 0 0 1 0 7.07"></path></svg>';

        this.muteButton.innerHTML = svg;
        this.muteButton.setAttribute('aria-label', this.isMuted ? 'Unmute video' : 'Mute video');
      }

      hideCoverAndButton() {
        if (this.coverImage) {
          this.coverImage.classList.add('hidden');
        }
        if (this.playButton) {
          this.playButton.classList.add('hidden');
        }
      }

      hideLeftOverlay() {
        if (this.leftOverlay) {
          this.leftOverlay.classList.add('hidden');
        }
      }

      showLeftOverlay() {
        if (this.leftOverlay) {
          this.leftOverlay.classList.remove('hidden');
        }
      }

      hideRightOverlay() {
        if (this.rightOverlay) {
          this.rightOverlay.classList.add('hidden');
        }
      }

      showRightOverlay() {
        if (this.rightOverlay) {
          this.rightOverlay.classList.remove('hidden');
        }
      }

      showThirdOverlay() {
        if (this.thirdOverlay) {
          this.thirdOverlay.classList.remove('hidden');
        }
      }

      hideThirdOverlay() {
        if (this.thirdOverlay) {
          this.thirdOverlay.classList.add('hidden');
        }
      }

      loadButtonVideo() {
        const buttonVideoType = this.imageButton?.dataset.buttonVideoType;
        if (!buttonVideoType) return;

        // Hide the image button when loading new video
        if (this.imageButton) {
          this.imageButton.classList.add('hidden');
        }

        // Manage overlay visibility
        this.hideLeftOverlay();
        this.hideRightOverlay();
        this.hideThirdOverlay();
        this.isPlayingButtonVideo = true;
        this.thirdOverlayShown = false;
        this.rightOverlayShown = false;

        if (buttonVideoType === 'shopify' && this.imageButton?.dataset.buttonVideoUrl) {
          // Load Shopify video
          if (this.videoElement) {
            this.videoElement.pause();
            // Store original video source
            this.originalVideoSrc = this.videoElement.querySelector('source')?.src;
            
            this.videoElement.src = this.imageButton.dataset.buttonVideoUrl;
            this.videoElement.load();
            this.videoElement.playbackRate = 0.5;
            this.playVideo();
            this.isPlaying = true;

            // Setup progress tracking for third overlay
            this.videoElement.addEventListener('timeupdate', () => this.handleButtonVideoProgress(), false);

            // Listen for video end
            this.videoElement.addEventListener('ended', () => this.onButtonVideoEnded(), { once: true });
          }
        } else if (buttonVideoType === 'youtube' && this.imageButton?.dataset.buttonVideoId) {
          // Load YouTube video
          if (this.youtubePlayer) {
            this.youtubePlayer.loadVideoById(this.imageButton.dataset.buttonVideoId);
            this.youtubePlayer.setPlaybackRate(0.5);
            this.youtubePlayer.playVideo();

            // Setup progress tracking
            this.youtubeProgressInterval = setInterval(() => this.handleYouTubeProgress(), 100);

            // Setup end event listener
            this.youtubePlayerStateListener = (event) => {
              if (event.data === 0) { // 0 = ENDED
                clearInterval(this.youtubeProgressInterval);
                this.youtubePlayer.removeEventListener('onStateChange', this.youtubePlayerStateListener);
                this.onButtonVideoEnded();
              }
            };
            this.youtubePlayer.addEventListener('onStateChange', this.youtubePlayerStateListener);
          }
        } else if (buttonVideoType === 'vimeo' && this.imageButton?.dataset.buttonVideoId) {
          // For Vimeo, reload the iframe
          const vimeoFrame = this.querySelector('#ai-vimeo-player-{{ ai_gen_id }}');
          if (vimeoFrame) {
            // Store original video ID
            this.originalVimeoId = vimeoFrame.src.match(/video\/(\d+)/)?.[1];
            
            vimeoFrame.src = `https://player.vimeo.com/video/${this.imageButton.dataset.buttonVideoId}?autoplay=1&muted=1`;
            
            // Set playback rate to 0.5x
            setTimeout(() => {
              vimeoFrame.contentWindow.postMessage({method: 'setPlaybackRate', value: 0.5}, '*');
            }, 500);
            
            // Setup progress tracking via postMessage
            this.vimeoProgressListener = (event) => {
              if (event.origin !== 'https://player.vimeo.com') return;
              if (event.data.event === 'timeupdate') {
                this.handleVimeoProgress(event.data);
              } else if (event.data.event === 'finish') {
                window.removeEventListener('message', this.vimeoProgressListener);
                window.removeEventListener('message', this.vimeoMessageListener);
                this.onButtonVideoEnded();
              }
            };
            window.addEventListener('message', this.vimeoProgressListener);
          }
        }
      }

      handleButtonVideoProgress() {
        if (!this.isPlayingButtonVideo || !this.videoElement) return;
        
        const duration = this.videoElement.duration;
        if (!duration || duration === 0) return;
        
        const currentTime = this.videoElement.currentTime;
        const progress = currentTime / duration;
        
        // Show right overlay at 1/10 of video length
        if (progress >= 0.1 && !this.rightOverlayShown) {
          this.showRightOverlay();
          this.rightOverlayShown = true;
        }
        
        // Hide right overlay at 1/3 of video length
        if (progress >= 0.3333 && this.rightOverlayShown) {
          this.hideRightOverlay();
          this.rightOverlayShown = false;
        }
        
        // Show third overlay at 1/2 of video length
        if (progress >= 0.5 && !this.thirdOverlayShown) {
          this.showThirdOverlay();
          this.thirdOverlayShown = true;
        }
        
        // Hide third overlay at 9/10 of video length
        if (progress >= 0.9 && this.thirdOverlayShown) {
          this.hideThirdOverlay();
          this.thirdOverlayShown = false;
        }
      }

      handleYouTubeProgress() {
        if (!this.isPlayingButtonVideo || !this.youtubePlayer) return;
        
        try {
          const currentTime = this.youtubePlayer.getCurrentTime();
          const duration = this.youtubePlayer.getDuration();
          
          if (!duration || duration === 0) return;
          
          const progress = currentTime / duration;
          
          // Show right overlay at 1/10 of video length
          if (progress >= 0.1 && !this.rightOverlayShown) {
            this.showRightOverlay();
            this.rightOverlayShown = true;
          }
          
          // Hide right overlay at 1/3 of video length
          if (progress >= 0.3333 && this.rightOverlayShown) {
            this.hideRightOverlay();
            this.rightOverlayShown = false;
          }
          
          // Show third overlay at 1/2 of video length
          if (progress >= 0.5 && !this.thirdOverlayShown) {
            this.showThirdOverlay();
            this.thirdOverlayShown = true;
          }
          
          // Hide third overlay at 9/10 of video length
          if (progress >= 0.9 && this.thirdOverlayShown) {
            this.hideThirdOverlay();
            this.thirdOverlayShown = false;
          }
        } catch (e) {
          // YouTube API might not be ready yet
        }
      }

      handleVimeoProgress(data) {
        if (!this.isPlayingButtonVideo) return;
        
        const progress = data.seconds / data.duration;
        
        // Show right overlay at 1/10 of video length
        if (progress >= 0.1 && !this.rightOverlayShown) {
          this.showRightOverlay();
          this.rightOverlayShown = true;
        }
        
        // Hide right overlay at 1/3 of video length
        if (progress >= 0.3333 && this.rightOverlayShown) {
          this.hideRightOverlay();
          this.rightOverlayShown = false;
        }
        
        // Show third overlay at 1/2 of video length
        if (progress >= 0.5 && !this.thirdOverlayShown) {
          this.showThirdOverlay();
          this.thirdOverlayShown = true;
        }
        
        // Hide third overlay at 9/10 of video length
        if (progress >= 0.9 && this.thirdOverlayShown) {
          this.hideThirdOverlay();
          this.thirdOverlayShown = false;
        }
      }

      onButtonVideoEnded() {
        // Cleanup progress tracking
        this.isPlayingButtonVideo = false;
        this.thirdOverlayShown = false;
        this.rightOverlayShown = false;
        if (this.youtubeProgressInterval) {
          clearInterval(this.youtubeProgressInterval);
        }
        
        // Remove Shopify video listener
        if (this.videoElement) {
          this.videoElement.removeEventListener('timeupdate', () => this.handleButtonVideoProgress());
        }
        
        // Remove Vimeo listeners
        if (this.vimeoProgressListener) {
          window.removeEventListener('message', this.vimeoProgressListener);
        }
        
        // Swap back to original video
        const videoType = this.dataset.videoType;

        if (videoType === 'shopify' && this.videoElement && this.originalVideoSrc) {
          this.videoElement.pause();
          this.videoElement.src = this.originalVideoSrc;
          this.videoElement.load();
          
          // Only auto-play if in auto-loop mode (1st video naturally ended, no user interaction)
          if (this.autoLoopMode) {
            this.videoElement.addEventListener('loadedmetadata', () => {
              this.playVideo();
              // Show image button after video starts playing
              if (this.imageButton) {
                this.imageButton.classList.remove('hidden');
              }
            }, { once: true });
          } else {
            // User clicked button - just show button, let user decide
            if (this.imageButton) {
              this.imageButton.classList.remove('hidden');
            }
          }
        } else if (videoType === 'youtube' && this.youtubePlayer) {
          const playerElement = this.querySelector('#ai-youtube-player-{{ ai_gen_id }}');
          const originalVideoId = playerElement.dataset.videoId;
          this.youtubePlayer.loadVideoById(originalVideoId);
          
          // Only auto-play if in auto-loop mode (1st video naturally ended, no user interaction)
          if (this.autoLoopMode) {
            this.youtubePlayer.playVideo();
            // Show image button after video starts playing
            if (this.imageButton) {
              this.imageButton.classList.remove('hidden');
            }
          } else {
            // User clicked button - just show button, let user decide
            if (this.imageButton) {
              this.imageButton.classList.remove('hidden');
            }
          }
        } else if (videoType === 'vimeo' && this.originalVimeoId) {
          const vimeoFrame = this.querySelector('#ai-vimeo-player-{{ ai_gen_id }}');
          if (vimeoFrame) {
            // Only auto-play if in auto-loop mode (1st video naturally ended, no user interaction)
            const shouldAutoPlay = this.autoLoopMode;
            vimeoFrame.src = `https://player.vimeo.com/video/${this.originalVimeoId}?autoplay=${shouldAutoPlay ? 1 : 0}&muted=1&loop=${this.loop ? 1 : 0}&background=1`;
            
            // Always show image button when returning to main video
            if (this.imageButton) {
              this.imageButton.classList.remove('hidden');
            }
          }
        }

        // Manage overlay visibility
        this.showLeftOverlay();
        this.hideRightOverlay();
        this.hideThirdOverlay();
      }
    }

    customElements.define('video-player-{{ ai_gen_id }}', VideoPlayer{{ ai_gen_id }});
  })();
</script>

