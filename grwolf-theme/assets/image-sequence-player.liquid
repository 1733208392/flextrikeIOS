{%- style -%}
  .image-sequence-player {
    position: relative;
    width: 100%;
    max-width: 800px;
    margin: 0 auto;
  }
  #sequence-canvas {
    width: 100%;
    height: auto;
    display: block;
  }
  #play-pause-btn {
    margin-top: 10px;
    padding: 5px 10px;
    background: #007bff;
    color: white;
    border: none;
    border-radius: 5px;
    cursor: pointer;
  }
  #play-pause-btn:hover {
    background: #0056b3;
  }
  #pois {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    aspect-ratio: 800 / 600;
    pointer-events: none;
  }
  .poi {
    pointer-events: auto;
  }
  .poi {
    position: absolute;
    width: 40px;
    height: 40px;
    background: rgba(255, 0, 0, 0.8);
    border: 2px solid white;
    border-radius: 50%;
    cursor: pointer;
    display: block; /* Always visible */
    z-index: 10;
    transform: translate(-50%, -50%);
  }
  .poi-text {
    position: absolute;
    background: rgba(0, 0, 0, 0.8);
    color: white;
    padding: 5px;
    border-radius: 5px;
    font-size: 14px;
    display: none;
    z-index: 15;
  }
{%- endstyle -%}

<div class="image-sequence-player">
  <canvas id="sequence-canvas" width="800" height="600"></canvas>
  <div id="pois">
    <!-- POIs will be added dynamically or via settings -->
  </div>
  <button id="play-pause-btn">Play</button>
  <input type="range" id="progress-bar" min="0" max="{{ section.settings.total_frames | default: 50 | minus: 1 }}" value="0">
</div>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const canvas = document.getElementById('sequence-canvas');
    const ctx = canvas.getContext('2d');
    const progressBar = document.getElementById('progress-bar');
    const playPauseBtn = document.getElementById('play-pause-btn');
    const poisContainer = document.getElementById('pois');

    const totalFrames = {{ section.settings.total_frames | default: 50 }};
    const framePrefix = '{{ section.settings.frame_prefix | default: "frame_" }}';
    const poisData = {{ section.settings.pois | default: '[]' | json }};

    // URLs array generated by Liquid
    const urls = [{%- for i in (1..section.settings.total_frames) -%}{%- assign padded_i = i -%}{%- if i < 10 -%}{%- assign padded_i = '000' | append: padded_i -%}{%- elsif i < 100 -%}{%- assign padded_i = '00' | append: padded_i -%}{%- else -%}{%- assign padded_i = '0' | append: padded_i -%}{%- endif -%}"{{ section.settings.frame_prefix | default: 'frame_' | append: padded_i | append: '.png' | asset_url }}"{%- if forloop.last == false -%},{%- endif -%}{%- endfor -%}];

    // Preload images
    const images = urls.map(url => {
      const img = new Image();
      img.src = url;
      return img;
    });

    // Draw first frame
    drawFrame(0);

    let currentFrame = 10;
    let isPlaying = false; // Don't auto-play
    let animationId;
    function drawFrame(frame) {
      if (images[frame] && images[frame].complete) {
        ctx.clearRect(0, 0, canvas.width, canvas.height);
        ctx.drawImage(images[frame], 0, 0, canvas.width, canvas.height);
      }
    }

    // Animation loop
    function animate() {
      if (isPlaying) {
        drawFrame(currentFrame);
        currentFrame = (currentFrame + 1) % totalFrames;
        progressBar.value = currentFrame;
      }
      animationId = requestAnimationFrame(animate);
    }

    // Progress bar change
    progressBar.addEventListener('input', function() {
      currentFrame = parseInt(this.value);
      drawFrame(currentFrame);
    });

    // Play/Pause button
    playPauseBtn.addEventListener('click', function() {
      isPlaying = !isPlaying;
      playPauseBtn.textContent = isPlaying ? 'Pause' : 'Play';
    });

    // POIs from settings
    let pois = [
      { frame: 1, x: 400, y: 300, text: 'Center POI' },
      { frame: 30, x: 400, y: 150, text: 'Top POI' },
      { frame: 50, x: 400, y: 450, text: 'Bottom POI' }
    ];
    if (poisData && Array.isArray(poisData) && poisData.length > 0) {
      pois = poisData;
    }
    console.log('poisData', poisData, 'pois', pois);

    pois.forEach(poi => {
      console.log('Adding POI', poi);
      const poiEl = document.createElement('div');
      poiEl.className = 'poi';
      
      // Get actual canvas size for proper positioning
      const canvasRect = canvas.getBoundingClientRect();
      const scaleX = canvasRect.width / 800;
      const scaleY = canvasRect.height / 600;
      
      // Position POI based on actual canvas size
      poiEl.style.left = (poi.x * scaleX) + 'px';
      poiEl.style.top = (poi.y * scaleY) + 'px';
      
      poiEl.addEventListener('click', function() {
        const textEl = document.createElement('div');
        textEl.className = 'poi-text';
        textEl.textContent = poi.text;
        textEl.style.left = ((poi.x + 25) * scaleX) + 'px';
        textEl.style.top = ((poi.y - 30) * scaleY) + 'px';
        poisContainer.appendChild(textEl);
        setTimeout(() => textEl.remove(), 3000); // Hide after 3s
      });
      poisContainer.appendChild(poiEl);
    });

    // Show POIs for current frame
    // Removed: POIs are always visible now

    // Start animation
    animate();

    // Update POIs in loop - removed, POIs always visible
  });
</script>

{% schema %}
{
  "name": "Image Sequence Player",
  "settings": [
    {
      "type": "text",
      "id": "frame_prefix",
      "label": "Frame Prefix",
      "default": "frame_"
    },
    {
      "type": "number",
      "id": "total_frames",
      "label": "Total Frames",
      "default": 50
    },
    {
      "type": "textarea",
      "id": "pois",
      "label": "POIs (JSON format: [{frame:10, x:100, y:200, text:'Text'}])"
    }
  ]
}
{% endschema %}