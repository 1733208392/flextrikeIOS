<style>
  .file-downloads {
    background: rgb(var(--color-background));
    padding: 60px 24px;
    min-height: 50vh;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .file-downloads__inner {
    max-width: 560px;
    width: 100%;
    margin: 0 auto;
  }
  .file-downloads__heading {
    font-size: clamp(1.5rem, 4vw, 2rem);
    font-weight: 700;
    color: rgb(var(--color-foreground));
    margin: 0 0 8px;
  }
  .file-downloads__subtext {
    font-size: 15px;
    color: rgba(var(--color-foreground), 0.55);
    margin: 0 0 40px;
    line-height: 1.6;
  }
  .file-downloads__list {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
  .file-downloads__item {
    display: flex;
    align-items: center;
    gap: 16px;
    padding: 20px 24px;
    border: 1px solid rgba(var(--color-foreground), 0.12);
    border-radius: 10px;
    text-decoration: none;
    color: rgb(var(--color-foreground));
    transition: border-color 0.2s, background 0.2s;
  }
  .file-downloads__item:hover {
    border-color: rgba(var(--color-foreground), 0.35);
    background: rgba(var(--color-foreground), 0.04);
  }
  .file-downloads__icon {
    flex-shrink: 0;
    width: 40px;
    height: 40px;
    background: rgba(var(--color-foreground), 0.07);
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: rgb(var(--color-foreground));
  }
  .file-downloads__label {
    flex: 1;
    font-size: 15px;
    font-weight: 600;
  }
  .file-downloads__dl-icon {
    flex-shrink: 0;
    opacity: 0.35;
  }
</style>

<div class="file-downloads">
  <div class="file-downloads__inner">

    {%- if section.settings.heading != blank -%}
      <h1 class="file-downloads__heading">{{ section.settings.heading }}</h1>
    {%- endif -%}

    {%- if section.settings.subtext != blank -%}
      <p class="file-downloads__subtext">{{ section.settings.subtext }}</p>
    {%- endif -%}

    <div class="file-downloads__list">

      {%- if section.settings.file1_url != blank -%}
        <a class="file-downloads__item" href="{{ section.settings.file1_url }}" download target="_blank" rel="noopener">
          <span class="file-downloads__icon">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="12" y1="18" x2="12" y2="12"/><polyline points="9 15 12 18 15 15"/></svg>
          </span>
          <span class="file-downloads__label">{{ section.settings.file1_label | default: 'Download File 1' }}</span>
          <span class="file-downloads__dl-icon">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
          </span>
        </a>
      {%- endif -%}

      {%- if section.settings.file2_url != blank -%}
        <a class="file-downloads__item" href="{{ section.settings.file2_url }}" download target="_blank" rel="noopener">
          <span class="file-downloads__icon">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="12" y1="18" x2="12" y2="12"/><polyline points="9 15 12 18 15 15"/></svg>
          </span>
          <span class="file-downloads__label">{{ section.settings.file2_label | default: 'Download File 2' }}</span>
          <span class="file-downloads__dl-icon">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
          </span>
        </a>
      {%- endif -%}

    </div>
  </div>
</div>

{% schema %}
{
  "name": "File Downloads",
  "settings": [
    { "type": "text",     "id": "heading", "label": "Heading", "default": "Downloads" },
    { "type": "textarea", "id": "subtext", "label": "Subtext",  "default": "Click a file below to download." },
    { "type": "header",   "content": "File 1" },
    { "type": "text", "id": "file1_label", "label": "Label", "default": "Compound Bow Assembly Guide" },
    { "type": "text", "id": "file1_url",   "label": "File URL", "info": "Paste the full CDN URL to the file.", "default": "https://cdn.shopify.com/s/files/1/0829/8800/7744/files/compoundbow-_assembly-v2.pdf?v=1777794303" },
    { "type": "header",   "content": "File 2" },
    { "type": "text", "id": "file2_label", "label": "Label", "default": "FlexTarget Menu" },
    { "type": "text", "id": "file2_url",   "label": "File URL", "info": "Paste the full CDN URL to the file.", "default": "https://cdn.shopify.com/s/files/1/0829/8800/7744/files/flextarget-menu.pdf?v=1777794301" }
  ],
  "presets": [{ "name": "File Downloads" }]
}
{% endschema %}
