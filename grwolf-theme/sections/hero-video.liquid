{%- assign sec_id = section.id -%}

{%- style -%}
  .hero-video-{{ sec_id }} {
    display: block;
    position: relative;
    width: 100%;
    margin: 0;
    padding: 0;
  }

  .hero-video-wrapper-{{ sec_id }} {
    position: relative;
    width: 100%;
    overflow: visible;
    background-color: #000000;
    height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  @media screen and (max-width: 749px) {
    .hero-video-wrapper-{{ sec_id }} {
      height: auto;
      aspect-ratio: 16 / 9;
      min-height: 300px;
    }
  }

  @media screen and (max-width: 500px) {
    .hero-video-wrapper-{{ sec_id }} {
      aspect-ratio: 16 / 9;
      min-height: 225px;
    }
  }

  .hero-video-container-{{ sec_id }} {
    position: relative;
    width: 100%;
    height: 100%;
    overflow: visible;
  }

  @media screen and (max-width: 749px) {
    .hero-video-container-{{ sec_id }} {
      aspect-ratio: 16 / 9;
    }
  }

  .hero-video-container-{{ sec_id }} video,
  .hero-video-container-{{ sec_id }} iframe {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .hero-video-cover-{{ sec_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 1;
    transition: opacity 0.3s ease;
  }

  .hero-video-cover-{{ sec_id }}.hidden {
    opacity: 0;
    pointer-events: none;
  }

  /* Dark gradient overlay on the video */
  .hero-video-dark-overlay-{{ sec_id }} {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      rgba(0, 0, 0, 0.55) 0%,
      rgba(0, 0, 0, 0.25) 50%,
      rgba(0, 0, 0, 0.60) 100%
    );
    z-index: 3;
    pointer-events: none;
  }

  /* Top-centered text overlay */
  .hero-video-overlay-{{ sec_id }} {
    position: absolute;
    left: 0;
    right: 0;
    top: 0;
    z-index: 4;
    color: #ffffff;
    font-weight: 700;
    font-size: 52px;
    line-height: 1.15;
    text-align: center;
    padding: 48px 40px 0;
    font-family: Helvetica, "Helvetica Neue", Arial, sans-serif;
    letter-spacing: -0.5px;
  }

  .hero-video-overlay-{{ sec_id }} .overlay-heading {
    color: #ffffff;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 1px;
    text-shadow: 0 2px 16px rgba(0, 0, 0, 0.8);
  }

  .hero-video-overlay-{{ sec_id }} .overlay-heading-accent {
    color: #DE3823;
  }

  .hero-video-overlay-{{ sec_id }} .overlay-subtitle {
    font-size: 0.52em;
    font-weight: 400;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.88);
    margin-top: 10px;
    text-shadow: 0 1px 8px rgba(0, 0, 0, 0.7);
  }

  /* CTA button */
  .hero-video-cta-btn-{{ sec_id }} {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    margin-top: 0;
    padding: 14px 28px;
    background-color: rgba(30, 30, 30, 0.85);
    color: #ffffff;
    font-size: 0.75em;
    font-weight: 500;
    font-family: Helvetica, "Helvetica Neue", Arial, sans-serif;
    letter-spacing: 0.3px;
    text-transform: none;
    text-decoration: none;
    border-radius: 9999px;
    border: 1px solid rgba(255, 255, 255, 0.15);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    transition: background-color 0.2s ease, transform 0.15s ease;
  }

  .hero-video-cta-btn-{{ sec_id }}::after {
    content: '›';
    font-size: 1.3em;
    line-height: 1;
    margin-top: -1px;
  }

  .hero-video-cta-btn-{{ sec_id }}:hover {
    background-color: rgba(50, 50, 50, 0.95);
    transform: translateY(-2px);
    color: #ffffff;
    text-decoration: none;
  }

  /* Mute/unmute button — bottom right */
  .hero-video-mute-btn-{{ sec_id }} {
    position: absolute;
    bottom: 24px;
    right: 24px;
    z-index: 5;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background-color: rgba(20, 20, 20, 0.7);
    border: 1px solid rgba(255, 255, 255, 0.25);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background-color 0.2s ease;
    padding: 0;
  }

  .hero-video-mute-btn-{{ sec_id }}:hover {
    background-color: rgba(50, 50, 50, 0.9);
  }

  .hero-video-mute-btn-{{ sec_id }} svg {
    width: 18px;
    height: 18px;
    fill: #ffffff;
  }

  .hero-video-bottom-{{ sec_id }} {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 36px;
    z-index: 4;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 14px;
    font-family: Helvetica, "Helvetica Neue", Arial, sans-serif;
  }

  .hero-video-bottom-{{ sec_id }} .bottom-tagline {
    color: rgba(255, 255, 255, 0.75);
    font-size: 13px;
    font-weight: 500;
    letter-spacing: 0.5px;
    text-shadow: 0 1px 4px rgba(0, 0, 0, 0.6);
  }

  /* Button row inside bottom area */
  .hero-video-btn-row-{{ sec_id }} {
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: 16px;
    flex-wrap: wrap;
    justify-content: center;
  }

  /* Centered button container */
  .hero-video-center-btn-{{ sec_id }} {
    position: absolute;
    top: 50%;
    left: 0;
    right: 0;
    transform: translateY(-50%);
    z-index: 4;
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 16px;
    flex-wrap: wrap;
    padding: 0 24px;
  }

  .hero-video-cta-btn2-{{ sec_id }} {
    background-color: transparent;
    border: 1px solid rgba(255, 255, 255, 0.5);
    cursor: pointer;
  }

  .hero-video-cta-btn2-{{ sec_id }}:hover {
    background-color: rgba(255, 255, 255, 0.1);
  }

  @media screen and (max-width: 1024px) {
    .hero-video-overlay-{{ sec_id }} {
      font-size: 40px;
      padding-top: 36px;
    }
  }

  @media screen and (max-width: 749px) {
    .hero-video-overlay-{{ sec_id }} {
      font-size: 24px;
      padding: 24px 16px 0;
    }

    .hero-video-bottom-{{ sec_id }} {
      bottom: 16px;
      gap: 10px;
    }

    .hero-video-bottom-{{ sec_id }} .bottom-tagline {
      font-size: 11px;
    }
  }

  @media screen and (max-width: 500px) {
    .hero-video-overlay-{{ sec_id }} {
      font-size: 18px;
      padding: 16px 12px 0;
    }

    .hero-video-bottom-{{ sec_id }} {
      bottom: 10px;
      gap: 8px;
    }

    .hero-video-bottom-{{ sec_id }} .bottom-tagline {
      font-size: 10px;
    }
  }
{%- endstyle -%}

<div class="hero-video-{{ sec_id }}" data-video-type="{{ section.settings.video_source }}" data-autoplay="true" data-loop="{{ section.settings.enable_loop }}">
  <div class="hero-video-wrapper-{{ sec_id }}">

    <div class="hero-video-dark-overlay-{{ sec_id }}"></div>

    {%- if section.settings.video_shopify != blank -%}
      <div class="hero-video-center-btn-{{ sec_id }}">

        <button
          class="hero-video-cta-btn-{{ sec_id }} hero-video-cta-btn2-{{ sec_id }}"
          data-vid-btn="0"
          data-src="{{ section.settings.video_shopify.sources[0].url }}"
          data-type="{{ section.settings.video_shopify.sources[0].mime_type }}"
          style="display:none"
        >{{ section.settings.cta1_label | default: 'Main Video' }}</button>

        {%- if section.settings.video_shopify_2 != blank -%}
          <button
            class="hero-video-cta-btn-{{ sec_id }} hero-video-cta-btn2-{{ sec_id }}"
            data-vid-btn="1"
            data-src="{{ section.settings.video_shopify_2.sources[0].url }}"
            data-type="{{ section.settings.video_shopify_2.sources[0].mime_type }}"
          >{{ section.settings.cta2_label | default: 'Look Into' }}</button>
        {%- endif -%}

        {%- if section.settings.video_shopify_3 != blank -%}
          <button
            class="hero-video-cta-btn-{{ sec_id }} hero-video-cta-btn2-{{ sec_id }}"
            data-vid-btn="2"
            data-src="{{ section.settings.video_shopify_3.sources[0].url }}"
            data-type="{{ section.settings.video_shopify_3.sources[0].mime_type }}"
          >{{ section.settings.cta3_label | default: 'How We Use It' }}</button>
        {%- endif -%}

      </div>
    {%- endif -%}

    <button class="hero-video-mute-btn-{{ sec_id }}" aria-label="Toggle mute" data-mute-btn>
      <svg class="icon-muted" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"><path d="M16.5 12A4.5 4.5 0 0 0 14 7.97v2.21l2.45 2.45c.03-.2.05-.41.05-.63zm2.5 0c0 .94-.2 1.82-.54 2.64l1.51 1.51A8.796 8.796 0 0 0 21 12c0-4.28-2.99-7.86-7-8.77v2.06c2.89.86 5 3.54 5 6.71zM4.27 3L3 4.27 7.73 9H3v6h4l5 5v-6.73l4.25 4.25c-.67.52-1.42.93-2.25 1.18v2.06A8.99 8.99 0 0 0 17.73 19L19 20.27 20.27 19 5.27 4 4.27 3zM12 4L9.91 6.09 12 8.18V4z"/></svg>
      <svg class="icon-unmuted" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" style="display:none"><path d="M3 9v6h4l5 5V4L7 9H3zm13.5 3A4.5 4.5 0 0 0 14 7.97v8.05c1.48-.73 2.5-2.25 2.5-4.02zM14 3.23v2.06c2.89.86 5 3.54 5 6.71s-2.11 5.85-5 6.71v2.06c4.01-.91 7-4.49 7-8.77s-2.99-7.86-7-8.77z"/></svg>
    </button>

    {%- if section.settings.video_shopify != blank -%}
      <div class="hero-video-container-{{ sec_id }}">
        <video
          class="hero-video-el-{{ sec_id }}"
          loop
          autoplay
          muted
          playsinline
          preload="auto"
        >
          {%- assign default_video = section.settings.video_shopify_2 | default: section.settings.video_shopify -%}
          {%- for source in default_video.sources -%}
            <source src="{{ source.url }}" type="{{ source.mime_type }}">
          {%- endfor -%}
        </video>

        {%- if section.settings.cover_image -%}
          <img
            src="{{ section.settings.cover_image | image_url: width: 1920 }}"
            alt="{{ section.settings.cover_image.alt | escape }}"
            class="hero-video-cover-{{ sec_id }}"
            loading="eager"
            width="{{ section.settings.cover_image.width }}"
            height="{{ section.settings.cover_image.height }}"
          >
        {%- endif -%}
      </div>
    {%- endif -%}

  </div>
</div>

<script>
  (function() {
    const wrapper = document.querySelector('.hero-video-wrapper-{{ sec_id }}');
    if (!wrapper) return;
    const video = wrapper.querySelector('.hero-video-el-{{ sec_id }}');
    const cover = wrapper.querySelector('.hero-video-cover-{{ sec_id }}');

    if (video) {
      const hideCover = function() {
        if (cover) cover.classList.add('hidden');
      };
      video.addEventListener('playing', hideCover);
      video.addEventListener('loadedmetadata', function() {
        video.play().catch(function() {});
      });
    }

    // Mute toggle
    const muteBtn = wrapper.querySelector('[data-mute-btn]');
    if (muteBtn && video) {
      const iconMuted = muteBtn.querySelector('.icon-muted');
      const iconUnmuted = muteBtn.querySelector('.icon-unmuted');
      muteBtn.addEventListener('click', function() {
        video.muted = !video.muted;
        iconMuted.style.display = video.muted ? '' : 'none';
        iconUnmuted.style.display = video.muted ? 'none' : '';
      });
    }

    // Multi-video button switcher
    var vidBtns = Array.from(wrapper.querySelectorAll('[data-vid-btn]'));
    var activeIndex = 1;
    var dotsInterval = null;

    function startDots(btn) {
      btn.disabled = true;
      btn._origLabel = btn.textContent.trim();
      var count = 0;
      btn.textContent = '.';
      dotsInterval = setInterval(function() {
        count = (count + 1) % 3;
        btn.textContent = '.'.repeat(count + 1);
      }, 400);
    }

    function stopDots(btn) {
      clearInterval(dotsInterval);
      dotsInterval = null;
      btn.textContent = btn._origLabel || '';
      btn.disabled = false;
    }

    function updateButtons() {
      vidBtns.forEach(function(b) {
        b.style.display = (parseInt(b.dataset.vidBtn, 10) === activeIndex) ? 'none' : '';
      });
    }

    if (video && vidBtns.length) {
      updateButtons();

      vidBtns.forEach(function(btn) {
        btn.addEventListener('click', function() {
          var idx = parseInt(btn.dataset.vidBtn, 10);
          if (idx === activeIndex) return;
          var src = btn.dataset.src;
          var type = btn.dataset.type;
          var source = video.querySelector('source');
          if (!source || !src) return;

          video.pause();
          startDots(btn);

          source.src = src;
          if (type) source.type = type;
          video.load();
          video.play().catch(function() {});

          function onReady() {
            stopDots(btn);
            activeIndex = idx;
            updateButtons();
            video.removeEventListener('playing', onReady);
            video.removeEventListener('error', onError);
          }
          function onError() {
            stopDots(btn);
            video.removeEventListener('playing', onReady);
            video.removeEventListener('error', onError);
          }
          video.addEventListener('playing', onReady);
          video.addEventListener('error', onError);
        });
      });
    }
  })();
</script>

{% schema %}
{
  "name": "Hero Video",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Video"
    },
    {
      "type": "video",
      "id": "video_shopify",
      "label": "Main video"
    },
    {
      "type": "header",
      "content": "Video 2"
    },
    {
      "type": "video",
      "id": "video_shopify_2",
      "label": "Second video"
    },
    {
      "type": "header",
      "content": "Video 3"
    },
    {
      "type": "video",
      "id": "video_shopify_3",
      "label": "Third video"
    },
    {
      "type": "header",
      "content": "Button Labels"
    },
    {
      "type": "text",
      "id": "cta1_label",
      "label": "Button label for main video",
      "default": "Main Video"
    },
    {
      "type": "text",
      "id": "cta2_label",
      "label": "Button label for video 2",
      "default": "Look Into"
    },
    {
      "type": "text",
      "id": "cta3_label",
      "label": "Button label for video 3",
      "default": "How We Use It"
    }
  ],
  "presets": [
    {
      "name": "Hero Video"
    }
  ]
}
{% endschema %}
