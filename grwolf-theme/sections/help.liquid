{% comment %}
Help section based on working B2B/Wholesale template
Features inline contact form for customer support inquiries
{% endcomment %}

<section class="section help-page">
  <style>
    /* Help page styles adapted from b2b-wholesale */
    *{box-sizing:border-box}
    .help-page { background: rgb(var(--color-background)); color: rgba(var(--color-foreground), 0.75); padding:0 }
    .help-content { max-width:720px; margin:0 auto; padding:60px 24px 24px; text-align:center }
    .help-main-title { font-size:48px; font-weight:700; letter-spacing:6px; text-transform:uppercase; margin-bottom:32px; background:linear-gradient(135deg,#ffffff 0%,#888 100%); -webkit-background-clip:text; -webkit-text-fill-color:transparent }
    .help-section { margin-bottom:48px }
    .help-subtitle { font-size:22px; font-weight:600; color:#e0e0e0; margin-bottom:12px; letter-spacing:1px }
    .accent-red { color: #de3823 !important }
    .help-desc { font-size:16px; line-height:1.7; color:#999; max-width:540px; margin:0 auto }
    .divider { width:60px; height:2px; background:linear-gradient(90deg,transparent,#444,transparent); margin:48px auto }
    .form-container-inline{background:#141414;border:1px solid #2a2a2a;border-radius:8px;padding:48px 40px;max-width:520px;width:100%;margin:0 auto;position:relative}
    .form-title{font-size:24px;font-weight:600;margin-bottom:32px}
    .form-group{margin-bottom:20px;text-align:left}
    .form-group label{display:block;font-size:13px;color:#888;margin-bottom:8px;letter-spacing:0.5px;text-transform:uppercase}
    .form-group input,.form-group textarea,.form-group select{width:100%;padding:12px 16px;font-size:15px;color:#fff;background:#1a1a1a;border:1px solid #333;border-radius:4px}
    .form-row{display:grid;grid-template-columns:1fr 1fr;gap:16px}
    .btn-submit{width:100%;padding:14px;font-size:15px;font-weight:600;letter-spacing:2px;text-transform:uppercase;color:#de3823 !important;background:linear-gradient(135deg,#1a1a2e,#16213e);border:1px solid #333;border-radius:4px;cursor:pointer}
    .btn-submit:hover{background:linear-gradient(135deg,#16213e,#0f3460);border-color:#555}
    .form-note{margin-top:16px;font-size:12px;color:#555}
    @media (max-width:600px){.help-main-title{font-size:32px;letter-spacing:4px}.help-content{padding:60px 20px 24px}.form-container-inline{padding:36px 24px}.form-row{grid-template-columns:1fr}}
  </style>

  <div class="help-content">
    <h1 class="help-main-title">Help Center</h1>

    <div class="help-section">
      <h2 class="help-subtitle accent-red">Need Help? Tell Us the Problem</h2>
      <p class="help-desc">Please describe the problem you encountered below, and we will handle it as soon as possible.</p>
    </div>

    <div class="divider"></div>

    <!-- Inline contact form -->
    <div class="form-container-inline">
      <h3 class="form-title">Submit Your Inquiry</h3>

      {% form 'contact', id: 'help-contact-form', class: 'help-contact-form' %}
        <input type="hidden" name="contact[tags]" value="help-inquiry">

        {%- if form.posted_successfully? -%}
          <div style="margin-bottom:20px;padding:14px;background:#1a4d2e;border:1px solid #2d5f3e;border-radius:4px;color:#9ad1ff;">
            Thank you — your inquiry was sent successfully!
          </div>
        {%- elsif form.errors -%}
          <div style="margin-bottom:20px;padding:14px;background:#4d1a1a;border:1px solid#5f2d2d;border-radius:4px;color:#ff9a9a;">
            {{ form.errors | default_errors }}
          </div>
        {%- endif -%}

        <div class="form-row">
          <div class="form-group">
            <label for="help-name">Name *</label>
            <input id="help-name" name="contact[name]" type="text" required placeholder="Your name">
          </div>
          <div class="form-group">
            <label for="help-email">Email *</label>
            <input id="help-email" name="contact[email]" type="email" required placeholder="you@example.com">
          </div>
        </div>

        <div class="form-group">
          <label for="help-order">Order Number (Optional)</label>
          <input id="help-order" name="contact[order_number]" type="text" placeholder="e.g. #1234">
        </div>

        <div class="form-group">
          <label for="help-message">Problem Description *</label>
          <textarea id="help-message" name="contact[body]" required placeholder="Tell us about the issue you're experiencing..."></textarea>
        </div>

        <button type="submit" class="btn-submit accent-red">Submit Inquiry</button>
        <p class="form-note">We'll respond within 24 business hours.</p>
      {% endform %}
    </div>
  </div>

  {% schema %}
  {
    "name": "Help",
    "settings": [],
    "blocks": [],
    "presets": [
      {"name":"Help Page"}
    ]
  }
  {% endschema %}

</section>
