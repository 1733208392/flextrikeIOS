{{ 'section-video-faq.css' | asset_url | stylesheet_tag }}
{{ 'component-slider.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

{%- liquid
  assign columns_mobile_int = section.settings.columns_mobile | plus: 0
  assign show_mobile_slider = false
  if section.settings.swipe_on_mobile and section.blocks.size > columns_mobile_int
    assign show_mobile_slider = true
  endif
-%}

<div class="video-faq-section color-{{ section.settings.color_scheme }} gradient{% if section.settings.heading == blank %} no-heading{% endif %}">
  <div
    class="page-width section-{{ section.id }}-padding isolate{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
    {% if settings.animations_reveal_on_scroll %}
      data-cascade
    {% endif %}
  >
    {%- unless section.settings.heading == blank -%}
      <div class="title-wrapper-with-link title-wrapper--self-padded-mobile title-wrapper--no-top-margin">
        <h2 class="video-faq__title inline-richtext {{ section.settings.heading_size }}">
          {{ section.settings.heading }}
        </h2>
        {%- if section.settings.subheading != blank -%}
          <div class="video-faq__subheading rte">
            {{ section.settings.subheading }}
          </div>
        {%- endif -%}
      </div>
    {%- endunless -%}

    <slider-component class="slider-mobile-gutter">
      <ul
        class="video-faq-grid grid grid--{{ section.settings.columns_mobile }}-col-tablet-down grid--{{ section.settings.columns_desktop }}-col-desktop{% if show_mobile_slider %} slider slider--tablet grid--peek{% endif %}"
        id="Slider-{{ section.id }}"
        role="list"
      >
        {%- for block in section.blocks -%}
          {%- case block.type -%}
            {%- when 'video_card' -%}
              <li
                id="Slide-{{ section.id }}-{{ forloop.index }}"
                class="video-faq-card grid__item{% if section.settings.swipe_on_mobile %} slider__slide{% endif %}{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
                {{ block.shopify_attributes }}
                {% if settings.animations_reveal_on_scroll %}
                  data-cascade
                  style="--animation-order: {{ forloop.index }};"
                {% endif %}
              >
                {%- if block.settings.video_url != blank -%}
                  <a href="{{ block.settings.video_url }}" class="video-faq-card__link" target="_blank" rel="noopener noreferrer">
                {%- endif -%}
                
                <div class="video-faq-card__wrapper">
                  {%- if block.settings.thumbnail != blank -%}
                    <div class="video-faq-card__thumbnail">
                      <img
                        srcset="
                          {%- if block.settings.thumbnail.width >= 165 -%}{{ block.settings.thumbnail | image_url: width: 165 }} 165w,{%- endif -%}
                          {%- if block.settings.thumbnail.width >= 360 -%}{{ block.settings.thumbnail | image_url: width: 360 }} 360w,{%- endif -%}
                          {%- if block.settings.thumbnail.width >= 533 -%}{{ block.settings.thumbnail | image_url: width: 533 }} 533w,{%- endif -%}
                          {%- if block.settings.thumbnail.width >= 720 -%}{{ block.settings.thumbnail | image_url: width: 720 }} 720w,{%- endif -%}
                          {%- if block.settings.thumbnail.width >= 940 -%}{{ block.settings.thumbnail | image_url: width: 940 }} 940w,{%- endif -%}
                          {%- if block.settings.thumbnail.width >= 1066 -%}{{ block.settings.thumbnail | image_url: width: 1066 }} 1066w,{%- endif -%}
                          {{ block.settings.thumbnail | image_url }} {{ block.settings.thumbnail.width }}w
                        "
                        src="{{ block.settings.thumbnail | image_url: width: 533 }}"
                        sizes="(min-width: {{ settings.page_width }}px) {{ settings.page_width | minus: 130 | divided_by: 4 }}px, (min-width: 990px) calc((100vw - 130px) / 4), (min-width: 750px) calc((100vw - 120px) / 3), calc((100vw - 35px) / 2)"
                        alt="{{ block.settings.thumbnail.alt | escape }}"
                        class="video-faq-card__image"
                        loading="lazy"
                        width="{{ block.settings.thumbnail.width }}"
                        height="{{ block.settings.thumbnail.height }}"
                      >
                      
                      {%- if block.settings.show_duration and block.settings.duration != blank -%}
                        <div class="video-faq-card__duration">
                          {{ block.settings.duration }}
                        </div>
                      {%- endif -%}
                      
                      {%- if block.settings.show_playlist_indicator -%}
                        <div class="video-faq-card__playlist-indicator">
                          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="20" height="20">
                            <path d="M22 7H2v1h20V7zm-9 5H2v-1h11v1zm0 4H2v-1h11v1zm2 3v-8l7 4-7 4z"/>
                          </svg>
                        </div>
                      {%- endif -%}
                    </div>
                  {%- else -%}
                    <div class="video-faq-card__thumbnail video-faq-card__thumbnail--placeholder">
                      {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg' }}
                      {%- if block.settings.show_duration and block.settings.duration != blank -%}
                        <div class="video-faq-card__duration">
                          {{ block.settings.duration }}
                        </div>
                      {%- endif -%}
                    </div>
                  {%- endif -%}

                  <div class="video-faq-card__content">
                    {%- if block.settings.title != blank -%}
                      <h3 class="video-faq-card__title">
                        {{ block.settings.title }}
                      </h3>
                    {%- endif -%}
                    
                    <div class="video-faq-card__meta">
                      {%- if block.settings.show_views and block.settings.views != blank -%}
                        <span class="video-faq-card__views">{{ block.settings.views }} views</span>
                      {%- endif -%}
                      {%- if block.settings.show_date and block.settings.date != blank -%}
                        <span class="video-faq-card__date">{{ block.settings.date }}</span>
                      {%- endif -%}
                    </div>
                  </div>
                </div>

                {%- if block.settings.video_url != blank -%}
                  </a>
                {%- endif -%}
              </li>
          {%- endcase -%}
        {%- endfor -%}
      </ul>

      {%- if show_mobile_slider -%}
        <div class="slider-buttons no-js-hidden">
          <button
            type="button"
            class="slider-button slider-button--prev"
            name="previous"
            aria-label="{{ 'general.slider.previous_slide' | t }}"
          >
            {% render 'icon-caret' %}
          </button>
          <div class="slider-counter caption">
            <span class="slider-counter--current">1</span>
            <span aria-hidden="true"> / </span>
            <span class="visually-hidden">{{ 'general.slider.of' | t }}</span>
            <span class="slider-counter--total">{{ section.blocks.size }}</span>
          </div>
          <button
            type="button"
            class="slider-button slider-button--next"
            name="next"
            aria-label="{{ 'general.slider.next_slide' | t }}"
          >
            {% render 'icon-caret' %}
          </button>
        </div>
      {%- endif -%}
    </slider-component>

    {%- if section.blocks.size == 0 -%}
      <div class="video-faq-empty-state">
        <p>{{ 'sections.video_faq.no_videos' | t | default: 'Add video cards from the section settings.' }}</p>
      </div>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "Video FAQ",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "inline_richtext",
      "id": "heading",
      "default": "Video Tutorials",
      "label": "Heading"
    },
    {
      "type": "richtext",
      "id": "subheading",
      "label": "Subheading"
    },
    {
      "type": "select",
      "id": "heading_size",
      "options": [
        {
          "value": "h2",
          "label": "Small"
        },
        {
          "value": "h1",
          "label": "Medium"
        },
        {
          "value": "h0",
          "label": "Large"
        }
      ],
      "default": "h1",
      "label": "Heading size"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "min": 1,
      "max": 4,
      "step": 1,
      "default": 3,
      "label": "Number of columns on desktop"
    },
    {
      "type": "select",
      "id": "color_scheme",
      "options": [
        {
          "value": "accent-1",
          "label": "Accent 1"
        },
        {
          "value": "accent-2",
          "label": "Accent 2"
        },
        {
          "value": "background-1",
          "label": "Background 1"
        },
        {
          "value": "background-2",
          "label": "Background 2"
        },
        {
          "value": "inverse",
          "label": "Inverse"
        }
      ],
      "default": "background-1",
      "label": "Color scheme"
    },
    {
      "type": "header",
      "content": "Mobile Layout"
    },
    {
      "type": "select",
      "id": "columns_mobile",
      "options": [
        {
          "value": "1",
          "label": "1 column"
        },
        {
          "value": "2",
          "label": "2 columns"
        }
      ],
      "default": "1",
      "label": "Number of columns on mobile"
    },
    {
      "type": "checkbox",
      "id": "swipe_on_mobile",
      "default": false,
      "label": "Enable swipe on mobile"
    },
    {
      "type": "header",
      "content": "Section Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 36
    }
  ],
  "blocks": [
    {
      "type": "video_card",
      "name": "Video Card",
      "settings": [
        {
          "type": "image_picker",
          "id": "thumbnail",
          "label": "Video Thumbnail"
        },
        {
          "type": "text",
          "id": "title",
          "default": "Video Title",
          "label": "Video Title"
        },
        {
          "type": "url",
          "id": "video_url",
          "label": "Video URL",
          "info": "Link to YouTube, Vimeo, or other video platform"
        },
        {
          "type": "text",
          "id": "duration",
          "label": "Video Duration",
          "default": "0:00",
          "info": "Example: 1:44 or 2:47"
        },
        {
          "type": "checkbox",
          "id": "show_duration",
          "default": true,
          "label": "Show duration badge"
        },
        {
          "type": "text",
          "id": "views",
          "label": "View Count",
          "default": "0",
          "info": "Example: 17 or 1.2K"
        },
        {
          "type": "checkbox",
          "id": "show_views",
          "default": true,
          "label": "Show view count"
        },
        {
          "type": "text",
          "id": "date",
          "label": "Date",
          "default": "5 days ago",
          "info": "Example: 5 days ago or Jan 15, 2024"
        },
        {
          "type": "checkbox",
          "id": "show_date",
          "default": true,
          "label": "Show date"
        },
        {
          "type": "checkbox",
          "id": "show_playlist_indicator",
          "default": false,
          "label": "Show playlist indicator icon"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Video FAQ",
      "blocks": [
        {
          "type": "video_card",
          "settings": {
            "title": "CQB & IPSC Stage Training at Home: Build Match-Ready Skills",
            "views": "17",
            "date": "5 days ago",
            "duration": "1:44"
          }
        },
        {
          "type": "video_card",
          "settings": {
            "title": "Can You Really Practice Home Defense at Home? (Yes — Here's How)",
            "views": "11",
            "date": "5 days ago",
            "duration": "2:15"
          }
        },
        {
          "type": "video_card",
          "settings": {
            "title": "FlexTarget Setup Tutorial | Unboxing & Quick Start Guide",
            "views": "8",
            "date": "5 days ago",
            "duration": "2:47"
          }
        }
      ]
    }
  ]
}
{% endschema %}
