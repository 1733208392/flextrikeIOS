{%- style -%}
  .wholesale-hero-{{ section.id }} {
    position: relative;
    background-color: #0a0a0a;
    color: #ffffff;
    min-height: 88vh;
    display: flex;
    align-items: center;
    overflow: hidden;
  }

  .wholesale-hero-{{ section.id }} .wholesale-hero__bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .wholesale-hero-{{ section.id }} .wholesale-hero__bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  .wholesale-hero-{{ section.id }} .wholesale-hero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(0, 0, 0, {{ section.settings.overlay_opacity | divided_by: 100.0 }}), rgba(20, 20, 20, 0.9));
    z-index: 1;
  }

  .wholesale-hero-{{ section.id }} .wholesale-hero__inner {
    width: 100%;
    max-width: 1200px;
    margin: 0 auto;
    padding: {{ section.settings.padding_top }}px 24px {{ section.settings.padding_bottom }}px;
    position: relative;
    z-index: 2;
    font-family: var(--font-body-family);
    text-align: center;
  }

  .wholesale-hero-{{ section.id }} .wholesale-hero__content {
    max-width: 860px;
    margin: 0 auto;
  }

  .wholesale-hero-{{ section.id }} .wholesale-hero__title {
    margin: 0 0 18px;
    font-size: clamp(2.25rem, 6vw, 4.25rem);
    letter-spacing: 0.06em;
    line-height: 1.05;
    text-transform: uppercase;
    font-weight: 800;
    color: #ffffff;
  }

  .wholesale-hero-{{ section.id }} .wholesale-hero__subtitle {
    margin: 0;
    font-size: clamp(1.25rem, 3vw, 1.85rem);
    color: #d4d4d4;
    line-height: 1.6;
  }

  .wholesale-hero-{{ section.id }} .wholesale-hero__hook {
    margin: 18px 0 0;
    color: #de3823;
    font-size: clamp(1.2rem, 3vw, 1.65rem);
    font-weight: 700;
    line-height: 1.5;
  }

  .wholesale-hero-{{ section.id }} .wholesale-hero__actions {
    margin-top: 34px;
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 12px;
  }

  .wholesale-hero-{{ section.id }} .wholesale-hero__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 52px;
    padding: 0 24px;
    border-radius: 999px;
    text-decoration: none;
    font-weight: 700;
    letter-spacing: 0.03em;
    border: 1px solid transparent;
    transition: transform 0.25s ease, background-color 0.25s ease, border-color 0.25s ease;
  }

  .wholesale-hero-{{ section.id }} .wholesale-hero__btn--primary {
    background: #de3823;
    color: #ffffff;
  }

  .wholesale-hero-{{ section.id }} .wholesale-hero__btn--secondary {
    background: rgba(10, 10, 10, 0.4);
    color: #ffffff;
    border-color: rgba(255, 255, 255, 0.3);
  }

  .wholesale-hero-{{ section.id }} .wholesale-hero__btn:hover {
    transform: translateY(-2px);
  }

  .wholesale-hero-{{ section.id }} .wholesale-hero__btn--secondary:hover {
    border-color: #de3823;
    color: #de3823;
  }

  /* ===== CTA wrapper + badge ===== */
  .wholesale-hero-{{ section.id }} .wholesale-hero__cta-wrapper {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 10px;
    margin-top: 28px;
  }

  .wholesale-hero-{{ section.id }} .cta-badge-container {
    position: relative;
    display: inline-block;
  }

  .wholesale-hero-{{ section.id }} .cta-main {
    display: inline-block;
    padding: 16px 42px;
    font-size: 17px;
    font-weight: 700;
    letter-spacing: 0.5px;
    border-radius: 6px;
    transition: transform 0.2s ease;
  }

  .wholesale-hero-{{ section.id }} .cta-main:hover {
    transform: translateY(-2px);
  }

  .wholesale-hero-{{ section.id }} .cta-badge {
    position: absolute;
    top: -14px;
    right: -28px;
    display: flex;
    align-items: center;
    gap: 5px;
    background: linear-gradient(135deg, #f97316, #ef4444);
    color: #fff;
    font-size: 13px;
    font-weight: 700;
    line-height: 1.3;
    padding: 6px 12px 6px 10px;
    border-radius: 8px;
    box-shadow: 0 4px 14px rgba(239, 68, 68, 0.35);
    transform: rotate(5deg);
    animation: badgeBounce 2s ease-in-out infinite;
    white-space: nowrap;
    cursor: default;
    z-index: 2;
  }

  .wholesale-hero-{{ section.id }} .cta-badge::after {
    content: "";
    position: absolute;
    bottom: -6px;
    left: 14px;
    width: 0;
    height: 0;
    border-left: 7px solid transparent;
    border-right: 7px solid transparent;
    border-top: 7px solid #ef4444;
  }

  .wholesale-hero-{{ section.id }} .cta-badge__icon {
    font-size: 18px;
    line-height: 1;
    animation: badgeShake 0.5s ease-in-out infinite;
    animation-delay: 1.5s;
  }

  .wholesale-hero-{{ section.id }} .wholesale-hero__hook-note {
    font-size: 12px;
    color: #ffffff;
    text-align: center;
    margin: 0;
  }

  @media screen and (max-width: 749px) {
    .wholesale-hero-{{ section.id }} {
      min-height: 76vh;
    }

    .wholesale-hero-{{ section.id }} .wholesale-hero__inner {
      padding: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px 20px {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
    }

    .wholesale-hero-{{ section.id }} .wholesale-hero__actions {
      gap: 10px;
    }

    .wholesale-hero-{{ section.id }} .wholesale-hero__btn {
      width: 100%;
    }

    .wholesale-hero-{{ section.id }} .cta-badge {
      top: -10px;
      right: -16px;
      font-size: 11px;
      padding: 4px 10px 4px 8px;
    }

    .wholesale-hero-{{ section.id }} .cta-badge__icon {
      font-size: 15px;
    }

    .wholesale-hero-{{ section.id }} .cta-main {
      padding: 14px 32px;
      font-size: 15px;
    }
  }
{%- endstyle -%}

<style>
  @keyframes badgeBounce {
    0%, 100% { transform: rotate(5deg) translateY(0); }
    50%       { transform: rotate(5deg) translateY(-3px); }
  }
  @keyframes badgeShake {
    0%, 100% { transform: rotate(0); }
    25%      { transform: rotate(-10deg); }
    75%      { transform: rotate(10deg); }
  }
</style>

<section id="{{ section.settings.section_id | default: 'wholesale-hero' }}" class="wholesale-hero-{{ section.id }}">
  <div class="wholesale-hero__bg" aria-hidden="true">
    {%- if section.settings.background_image != blank -%}
      {{
        section.settings.background_image
        | image_url: width: 2400
        | image_tag:
          loading: 'eager',
          fetchpriority: 'high',
          widths: '750, 1100, 1500, 2000, 2400',
          sizes: '100vw',
          alt: section.settings.heading
      }}
    {%- endif -%}
  </div>
  <div class="wholesale-hero__overlay" aria-hidden="true"></div>

  <div class="wholesale-hero__inner">
    <div class="wholesale-hero__content">
      <h1 class="wholesale-hero__title">{{ section.settings.heading }}</h1>
      <p class="wholesale-hero__subtitle">{{ section.settings.subtitle }}</p>
      <p class="wholesale-hero__hook">{{ section.settings.value_hook }}</p>

      <div class="wholesale-hero__actions">
        <div class="wholesale-hero__cta-wrapper">
          <div class="cta-badge-container">
            <a class="wholesale-hero__btn wholesale-hero__btn--primary cta-main" href="{{ section.settings.primary_cta_link | default: '#wholesale-inquiry-form' }}">
              {{ section.settings.primary_cta_label }}
            </a>
            <div class="cta-badge" aria-label="Win a Free Demo">
              <span class="cta-badge__icon">🎁</span>
              <span>Win a<br>Free Demo</span>
            </div>
          </div>
          <p class="wholesale-hero__hook-note">No purchase required. One winner every month.</p>
        </div>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Wholesale Hero",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "text",
      "id": "section_id",
      "label": "Section anchor ID",
      "default": "wholesale-hero"
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background image"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "min": 20,
      "max": 90,
      "step": 5,
      "unit": "%",
      "label": "Overlay opacity",
      "default": 55
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "GRWOLF WHOLESALE"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Premium Fitness Equipment - Factory-Direct Pricing"
    },
    {
      "type": "text",
      "id": "value_hook",
      "label": "Value hook",
      "default": "Up to 50% Off on 10+ Units"
    },
    {
      "type": "text",
      "id": "primary_cta_label",
      "label": "Primary CTA label",
      "default": "Request Quote"
    },
    {
      "type": "text",
      "id": "primary_cta_link",
      "label": "Primary CTA link"
    },
    {
      "type": "header",
      "content": "Section spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 40,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 100
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 40,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 100
    }
  ],
  "presets": [
    {
      "name": "Wholesale Hero"
    }
  ]
}
{% endschema %}
