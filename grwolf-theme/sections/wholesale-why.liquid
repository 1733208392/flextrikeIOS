{%- style -%}
  .wholesale-why-{{ section.id }} {
    background: #111111;
    color: #ffffff;
  }

  .wholesale-why-{{ section.id }} .wholesale-why__inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: {{ section.settings.padding_top }}px 24px {{ section.settings.padding_bottom }}px;
    font-family: var(--font-body-family);
  }

  .wholesale-why-{{ section.id }} .wholesale-why__heading {
    margin: 0;
    text-align: center;
    font-size: clamp(2.25rem, 4.5vw, 3.5rem);
    line-height: 1.15;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .wholesale-why-{{ section.id }} .wholesale-why__subheading {
    margin: 16px auto 0;
    max-width: 800px;
    text-align: center;
    color: #bbbbbb;
    font-size: clamp(1.1rem, 2vw, 1.35rem);
    line-height: 1.75;
  }

  .wholesale-why-{{ section.id }} .wholesale-why__grid {
    margin-top: 40px;
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 18px;
  }

  .wholesale-why-{{ section.id }} .wholesale-why__card {
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.03), rgba(255, 255, 255, 0.01));
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 16px;
    padding: 32px 26px;
    text-align: center;
    min-height: 240px;
  }

  .wholesale-why-{{ section.id }} .wholesale-why__icon {
    width: 72px;
    height: 72px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 20px;
    overflow: hidden;
  }

  .wholesale-why-{{ section.id }} .wholesale-why__icon img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .wholesale-why-{{ section.id }} .wholesale-why__title {
    margin: 0;
    font-size: clamp(1.25rem, 2.2vw, 1.6rem);
    line-height: 1.3;
  }

  .wholesale-why-{{ section.id }} .wholesale-why__desc {
    margin: 12px 0 0;
    font-size: clamp(1rem, 1.6vw, 1.15rem);
    line-height: 1.75;
    color: #b3b3b3;
  }

  @media screen and (max-width: 989px) {
    .wholesale-why-{{ section.id }} .wholesale-why__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media screen and (max-width: 749px) {
    .wholesale-why-{{ section.id }} .wholesale-why__inner {
      padding: {{ section.settings.padding_top | times: 0.65 | round: 0 }}px 20px {{ section.settings.padding_bottom | times: 0.65 | round: 0 }}px;
    }

    .wholesale-why-{{ section.id }} .wholesale-why__grid {
      grid-template-columns: 1fr;
      gap: 14px;
      margin-top: 28px;
    }
  }
{%- endstyle -%}

<section id="{{ section.settings.section_id | default: 'wholesale-why' }}" class="wholesale-why-{{ section.id }}">
  <div class="wholesale-why__inner">
    <h2 class="wholesale-why__heading">{{ section.settings.heading }}</h2>
    <p class="wholesale-why__subheading">{{ section.settings.subheading }}</p>

    <div class="wholesale-why__grid">
      {%- for block in section.blocks -%}
        <article class="wholesale-why__card" {{ block.shopify_attributes }}>
          <div class="wholesale-why__icon">
            {%- if block.settings.icon_image != blank -%}
              {{ block.settings.icon_image | image_url: width: 144 | image_tag: loading: 'lazy', widths: '72, 144', sizes: '72px', alt: block.settings.title }}
            {%- endif -%}
          </div>
          <h3 class="wholesale-why__title">{{ block.settings.title }}</h3>
          <p class="wholesale-why__desc">{{ block.settings.description }}</p>
        </article>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Wholesale Why",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "text",
      "id": "section_id",
      "label": "Section anchor ID",
      "default": "wholesale-why"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Why GRWOLF"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Built for distributors, retailers, and training facilities that need quality, speed, and margin confidence."
    },
    {
      "type": "header",
      "content": "Section spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 40,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 96
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 40,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 96
    }
  ],
  "blocks": [
    {
      "type": "benefit",
      "name": "Benefit card",
      "settings": [
        {
          "type": "image_picker",
          "id": "icon_image",
          "label": "Icon image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Factory-Direct"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "No middlemen. Transparent pricing from our production line to your warehouse."
        }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [
    {
      "name": "Wholesale Why",
      "blocks": [
        {
          "type": "benefit",
          "settings": {
            "title": "Factory-Direct",
            "description": "No middlemen. Transparent pricing from our production line to your warehouse."
          }
        },
        {
          "type": "benefit",
          "settings": {
            "title": "Fast Shipping",
            "description": "In-stock SKUs ship in as little as 7 days with reliable fulfillment support."
          }
        },
        {
          "type": "benefit",
          "settings": {
            "title": "OEM Ready",
            "description": "Launch custom branding and packaging programs with a 50-unit MOQ."
          }
        }
      ]
    }
  ]
}
{% endschema %}
