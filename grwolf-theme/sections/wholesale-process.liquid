{%- style -%}
  .wholesale-process-{{ section.id }} {
    background: #0d0d0d;
    color: #ffffff;
  }

  .wholesale-process-{{ section.id }} .wholesale-process__inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: {{ section.settings.padding_top }}px 24px {{ section.settings.padding_bottom }}px;
    font-family: var(--font-body-family);
  }

  .wholesale-process-{{ section.id }} .wholesale-process__heading {
    margin: 0;
    text-align: center;
    font-size: clamp(1.75rem, 3.4vw, 2.75rem);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    line-height: 1.2;
  }

  .wholesale-process-{{ section.id }} .wholesale-process__subheading {
    margin: 14px auto 0;
    max-width: 720px;
    text-align: center;
    color: #bbbbbb;
    line-height: 1.7;
  }

  .wholesale-process-{{ section.id }} .wholesale-process__track {
    margin-top: 42px;
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 18px;
    align-items: center;
  }

  .wholesale-process-{{ section.id }} .wholesale-process__step {
    position: relative;
    background: #141414;
    border: 1px solid rgba(255, 255, 255, 0.14);
    border-radius: 14px;
    padding: 18px 14px;
    min-height: 0;
  }

  .wholesale-process-{{ section.id }} .wholesale-process__step:not(:last-child)::after {
    content: '→';
    position: absolute;
    right: -15px;
    top: 50%;
    transform: translateY(-50%);
    color: #de3823;
    font-size: 24px;
    font-weight: 700;
    z-index: 2;
  }

  .wholesale-process-{{ section.id }} .wholesale-process__step-header {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    margin-bottom: 10px;
  }

  .wholesale-process-{{ section.id }} .wholesale-process__num {
    flex-shrink: 0;
    display: inline-flex;
    width: 36px;
    height: 36px;
    align-items: center;
    justify-content: center;
    border-radius: 999px;
    background: #de3823;
    color: #ffffff;
    font-size: 15px;
    font-weight: 700;
  }

  .wholesale-process-{{ section.id }} .wholesale-process__icon {
    width: 44px;
    height: 44px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .wholesale-process-{{ section.id }} .wholesale-process__icon img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .wholesale-process-{{ section.id }} .wholesale-process__title {
    margin: 0 0 8px;
    font-size: clamp(1.05rem, 1.8vw, 1.25rem);
    line-height: 1.3;
    text-align: center;
  }

  .wholesale-process-{{ section.id }} .wholesale-process__text {
    margin: 0;
    color: #b7b7b7;
    line-height: 1.6;
    font-size: clamp(0.95rem, 1.4vw, 1.05rem);
    text-align: center;
  }

  @media screen and (max-width: 900px) {
    .wholesale-process-{{ section.id }} .wholesale-process__track {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .wholesale-process-{{ section.id }} .wholesale-process__step::after {
      content: none;
    }
  }

  @media screen and (max-width: 749px) {
    .wholesale-process-{{ section.id }} .wholesale-process__inner {
      padding: {{ section.settings.padding_top | times: 0.65 | round: 0 }}px 20px {{ section.settings.padding_bottom | times: 0.65 | round: 0 }}px;
    }

    .wholesale-process-{{ section.id }} .wholesale-process__track {
      margin-top: 28px;
      grid-template-columns: 1fr;
      gap: 12px;
    }

    .wholesale-process-{{ section.id }} .wholesale-process__step {
      min-height: auto;
    }
  }
{%- endstyle -%}

<section id="{{ section.settings.section_id | default: 'wholesale-process' }}" class="wholesale-process-{{ section.id }}">
  <div class="wholesale-process__inner">
    <h2 class="wholesale-process__heading">{{ section.settings.heading }}</h2>
    <p class="wholesale-process__subheading">{{ section.settings.subheading }}</p>

    <div class="wholesale-process__track">
      {%- for block in section.blocks -%}
        <article class="wholesale-process__step" {{ block.shopify_attributes }}>
          <div class="wholesale-process__step-header">
            <span class="wholesale-process__num">{{ block.settings.step_number | default: forloop.index }}</span>
            <div class="wholesale-process__icon">
              {%- if block.settings.icon_image != blank -%}
                {{ block.settings.icon_image | image_url: width: 88 | image_tag: loading: 'lazy', widths: '44, 88', sizes: '44px', alt: block.settings.title }}
              {%- endif -%}
            </div>
          </div>
          <h3 class="wholesale-process__title">{{ block.settings.title }}</h3>
          <p class="wholesale-process__text">{{ block.settings.description }}</p>
        </article>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Wholesale Process",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "text",
      "id": "section_id",
      "label": "Section anchor ID",
      "default": "wholesale-process"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "How It Works"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "From inquiry to delivery, our team keeps the process fast, clear, and trackable."
    },
    {
      "type": "header",
      "content": "Section spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 40,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 96
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 40,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 96
    }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Step",
      "settings": [
        {
          "type": "text",
          "id": "step_number",
          "label": "Step number",
          "default": "1"
        },
        {
          "type": "image_picker",
          "id": "icon_image",
          "label": "Icon image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Send Inquiry"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "Share your product goals, expected quantity, and delivery region."
        }
      ]
    }
  ],
  "max_blocks": 4,
  "presets": [
    {
      "name": "Wholesale Process",
      "blocks": [
        {
          "type": "step",
          "settings": {
            "step_number": "1",
            "title": "Send Inquiry",
            "description": "Fill out the wholesale form and tell us what your market needs."
          }
        },
        {
          "type": "step",
          "settings": {
            "step_number": "2",
            "title": "Get Quote",
            "description": "Receive your custom quote within 24 business hours."
          }
        },
        {
          "type": "step",
          "settings": {
            "step_number": "3",
            "title": "Confirm & Pay",
            "description": "Approve specs, confirm terms, and pay using your preferred method."
          }
        },
        {
          "type": "step",
          "settings": {
            "step_number": "4",
            "title": "Ship",
            "description": "We dispatch your order with active tracking from pickup to delivery."
          }
        }
      ]
    }
  ]
}
{% endschema %}
