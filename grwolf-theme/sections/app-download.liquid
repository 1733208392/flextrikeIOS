<style>
  .app-qr {
    background: rgb(var(--color-background));
    min-height: 70vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 60px 24px;
  }
  .app-qr__inner { max-width: 480px; width: 100%; text-align: center; margin: 0 auto; }
  .app-qr__heading { font-size: clamp(1.5rem, 4vw, 2.2rem); font-weight: 700; color: rgb(var(--color-foreground)); margin: 0 0 12px; letter-spacing: 0.02em; }
  .app-qr__subtext { font-size: 15px; line-height: 1.7; color: rgba(var(--color-foreground), 0.55); margin: 0 0 36px; }
  .app-qr__code-wrap { display: inline-block; background: #fff; border-radius: 16px; padding: 20px; box-shadow: 0 4px 24px rgba(0,0,0,0.18); margin-bottom: 24px; text-decoration: none; }
  .app-qr__code-wrap img { display: block; width: 200px; height: 200px; object-fit: contain; }
  .app-qr__hint { font-size: 13px; color: rgba(var(--color-foreground), 0.35); margin: 0 0 32px; }
  .app-qr__badges { display: flex; flex-wrap: wrap; gap: 12px; justify-content: center; }
  .app-qr__badge { display: inline-flex; align-items: center; gap: 8px; padding: 10px 20px; border-radius: 8px; font-size: 13px; font-weight: 600; text-decoration: none; opacity: 0.4; border: 1px solid rgba(var(--color-foreground), 0.2); color: rgba(var(--color-foreground), 0.6); }
  @media (max-width: 480px) { .app-qr__code-wrap img { width: 160px; height: 160px; } }
</style>

<div class="app-qr">
  <div class="app-qr__inner">

    {%- if section.settings.heading != blank -%}
      <h1 class="app-qr__heading">{{ section.settings.heading }}</h1>
    {%- endif -%}

    {%- if section.settings.subtext != blank -%}
      <p class="app-qr__subtext">{{ section.settings.subtext }}</p>
    {%- endif -%}

    {%- assign redirect_path = section.settings.redirect_page_url | default: '/pages/appstore-redirect' -%}
    {%- assign qr_target = redirect_path | prepend: 'https://grwolf.com' | url_encode -%}

    <a href="{{ redirect_path }}" class="app-qr__code-wrap" aria-label="Scan to download the app">
      {%- if section.settings.qr_image != blank -%}
        <img src="{{ section.settings.qr_image | image_url: width: 400 }}" alt="QR code — scan to download" width="200" height="200">
      {%- else -%}
        <img src="https://api.qrserver.com/v1/create-qr-code/?size=400x400&margin=0&data={{ qr_target }}" alt="QR code — scan to download" width="200" height="200">
      {%- endif -%}
    </a>

    <p class="app-qr__hint">{{ section.settings.hint | default: 'Scan with your phone camera to download' }}</p>

    <div class="app-qr__badges">
      <span class="app-qr__badge">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/></svg>
        iOS
      </span>
      <span class="app-qr__badge">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.6 9.48l1.84-3.18c.16-.31.04-.69-.26-.85a.637.637 0 0 0-.83.22l-1.88 3.24a11.46 11.46 0 0 0-8.94 0L5.65 5.67a.643.643 0 0 0-.87-.2c-.28.18-.37.54-.22.83L6.4 9.48A10.78 10.78 0 0 0 1 18h22a10.78 10.78 0 0 0-5.4-8.52zM7 15.25a1.25 1.25 0 1 1 0-2.5 1.25 1.25 0 0 1 0 2.5zm10 0a1.25 1.25 0 1 1 0-2.5 1.25 1.25 0 0 1 0 2.5z"/></svg>
        Android
      </span>
    </div>

  </div>
</div>

{% schema %}
{
  "name": "App Download (QR)",
  "settings": [
    { "type": "text",         "id": "heading",          "label": "Heading",            "default": "Download the FlexTarget App" },
    { "type": "textarea",     "id": "subtext",           "label": "Subtext",            "default": "Scan the QR code with your phone camera. Automatically opens App Store or Google Play." },
    { "type": "text",         "id": "hint",              "label": "QR hint text",       "default": "Scan with your phone camera to download" },
    { "type": "header",       "content": "QR Code" },
    { "type": "image_picker", "id": "qr_image",          "label": "QR code image",      "info": "Upload your own QR code image. If blank, one is auto-generated pointing to the redirect page." },
    { "type": "text",         "id": "redirect_page_url", "label": "Redirect page path", "default": "/pages/appstore-redirect", "info": "Path to your appstore-redirect page. QR code will point here." }
  ],
  "presets": [{ "name": "App Download (QR)" }]
}
{% endschema %}
