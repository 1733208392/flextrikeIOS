<style>
  .app-download {
    background: rgb(var(--color-background));
    color: rgba(var(--color-foreground), 0.75);
    padding: 80px 24px;
    text-align: center;
  }
  .app-download__inner { max-width: 480px; margin: 0 auto; }
  .app-download__heading {
    font-size: clamp(1.6rem, 4vw, 2.4rem); font-weight: 700;
    color: rgb(var(--color-foreground)); margin-bottom: 12px;
  }
  .app-download__subtext {
    font-size: 16px; line-height: 1.7;
    color: rgba(var(--color-foreground), 0.6); margin-bottom: 40px;
  }
  .app-download__qr-wrap {
    display: inline-block;
    background: #fff;
    border-radius: 16px;
    padding: 16px;
    box-shadow: 0 4px 24px rgba(0,0,0,0.18);
    margin-bottom: 16px;
  }
  .app-download__qr-wrap img { display: block; width: 200px; height: 200px; }
  .app-download__qr-hint {
    font-size: 13px; color: rgba(var(--color-foreground), 0.45);
    margin-bottom: 40px; letter-spacing: 0.03em;
  }
  .app-download__divider {
    display: flex; align-items: center; gap: 12px;
    margin-bottom: 24px; color: rgba(var(--color-foreground), 0.3); font-size: 13px;
  }
  .app-download__divider::before,
  .app-download__divider::after {
    content: ''; flex: 1; height: 1px; background: rgba(var(--color-foreground), 0.12);
  }
  .app-download__buttons { display: flex; flex-direction: column; gap: 12px; }
  .app-download__btn {
    display: inline-flex; align-items: center; justify-content: center; gap: 10px;
    padding: 14px 24px; border-radius: 8px; font-size: 15px; font-weight: 600;
    text-decoration: none; letter-spacing: 0.03em; transition: opacity 0.2s ease;
    border: 2px solid transparent;
  }
  .app-download__btn:hover { opacity: 0.82; }
  .app-download__btn--ios { background: #000; color: #fff; }
  .app-download__btn--android { background: #1a73e8; color: #fff; }
  .app-download__btn--apk {
    background: transparent; color: rgb(var(--color-foreground));
    border-color: rgba(var(--color-foreground), 0.25);
  }
</style>

<div class="app-download">
  <div class="app-download__inner">

    {%- if section.settings.heading != blank -%}
      <h1 class="app-download__heading">{{ section.settings.heading }}</h1>
    {%- endif -%}

    {%- if section.settings.subtext != blank -%}
      <p class="app-download__subtext">{{ section.settings.subtext }}</p>
    {%- endif -%}

    {%- if section.settings.qr_image != blank -%}
      <a href="{{ section.settings.qr_link | default: '/pages/app-redirect' }}" class="app-download__qr-wrap">
        <img src="{{ section.settings.qr_image | image_url: width: 400 }}"
             alt="Scan to download" width="200" height="200">
      </a>
      <p class="app-download__qr-hint">{{ section.settings.qr_hint | default: 'Scan with your phone camera to download' }}</p>
    {%- endif -%}

    <div class="app-download__divider">or download directly</div>

    <div class="app-download__buttons">
      {%- if section.settings.ios_url != blank -%}
        <a class="app-download__btn app-download__btn--ios" href="{{ section.settings.ios_url }}">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/></svg>
          {{ section.settings.ios_label | default: 'Download on App Store' }}
        </a>
      {%- endif -%}
      {%- if section.settings.android_url != blank -%}
        <a class="app-download__btn app-download__btn--android" href="{{ section.settings.android_url }}">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M17.523 15.341l-5.02-5.021 5.02-5.02-1.414-1.415-5.02 5.02-5.021-5.02-1.414 1.415 5.02 5.02-5.02 5.021 1.414 1.414 5.021-5.02 5.02 5.02 1.414-1.414z"/><path d="M1 21l3.5-6.06A9 9 0 1 1 12 21H1z"/></svg>
          {{ section.settings.android_label | default: 'Get it on Google Play' }}
        </a>
      {%- endif -%}
      {%- if section.settings.apk_url != blank -%}
        <a class="app-download__btn app-download__btn--apk" href="{{ section.settings.apk_url }}" download>
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M19 9h-4V3H9v6H5l7 7 7-7zM5 18v2h14v-2H5z"/></svg>
          {{ section.settings.apk_label | default: 'Download APK (Android)' }}
        </a>
      {%- endif -%}
    </div>

  </div>
</div>

{% schema %}
{
  "name": "App Download",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Download the FlexTarget App" },
    { "type": "textarea", "id": "subtext", "label": "Subtext", "default": "Scan the QR code with your phone camera to download." },
    { "type": "header", "content": "QR Code" },
    { "type": "image_picker", "id": "qr_image", "label": "QR code image" },
    { "type": "text", "id": "qr_hint", "label": "QR code hint text", "default": "Scan with your phone camera to download" },
    { "type": "url", "id": "qr_link", "label": "QR code destination URL", "info": "Set to /pages/app-redirect for auto-redirect" },
    { "type": "header", "content": "iOS" },
    { "type": "url", "id": "ios_url", "label": "App Store URL" },
    { "type": "text", "id": "ios_label", "label": "Button label", "default": "Download on App Store" },
    { "type": "header", "content": "Android" },
    { "type": "url", "id": "android_url", "label": "Google Play URL" },
    { "type": "text", "id": "android_label", "label": "Button label", "default": "Get it on Google Play" },
    { "type": "header", "content": "Direct APK" },
    { "type": "url", "id": "apk_url", "label": "APK file URL" },
    { "type": "text", "id": "apk_label", "label": "Button label", "default": "Download APK (Android)" }
  ],
  "presets": [{ "name": "App Download" }]
}
{% endschema %}
