<style>
  .app-download {
    background: rgb(var(--color-background));
    color: rgba(var(--color-foreground), 0.75);
    min-height: 60vh;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 60px 24px;
  }
  .app-download__inner { max-width: 560px; margin: 0 auto; }
  .app-download__heading { font-size: clamp(1.6rem, 4vw, 2.4rem); font-weight: 700; color: rgb(var(--color-foreground)); margin-bottom: 16px; }
  .app-download__subtext { font-size: 16px; line-height: 1.7; color: rgba(var(--color-foreground), 0.6); margin-bottom: 40px; }
  .app-download__buttons { display: flex; flex-wrap: wrap; gap: 16px; justify-content: center; }
  .app-download__btn {
    display: inline-flex; align-items: center; gap: 10px;
    padding: 14px 28px; border-radius: 6px; font-size: 15px; font-weight: 600;
    text-decoration: none; letter-spacing: 0.03em; transition: opacity 0.2s ease;
    border: 2px solid transparent;
  }
  .app-download__btn:hover { opacity: 0.85; }
  .app-download__btn--ios { background: #000; color: #fff; }
  .app-download__btn--android { background: #1a73e8; color: #fff; }
  .app-download__btn--apk { background: transparent; color: rgb(var(--color-foreground)); border-color: rgba(var(--color-foreground), 0.3); }
  .app-download__redirect-msg { font-size: 14px; color: rgba(var(--color-foreground), 0.4); margin-top: 32px; }
</style>

<div class="app-download">
  <div class="app-download__inner">

    {%- if section.settings.heading != blank -%}
      <h1 class="app-download__heading">{{ section.settings.heading }}</h1>
    {%- endif -%}

    {%- if section.settings.subtext != blank -%}
      <p class="app-download__subtext">{{ section.settings.subtext }}</p>
    {%- endif -%}

    <div class="app-download__buttons">
      {%- if section.settings.ios_url != blank -%}
        <a class="app-download__btn app-download__btn--ios" href="{{ section.settings.ios_url }}" id="btn-ios">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/></svg>
          {{ section.settings.ios_label | default: 'Download on App Store' }}
        </a>
      {%- endif -%}

      {%- if section.settings.android_url != blank -%}
        <a class="app-download__btn app-download__btn--android" href="{{ section.settings.android_url }}" id="btn-android">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M17.523 15.341l-5.02-5.021 5.02-5.02-1.414-1.415-5.02 5.02-5.021-5.02-1.414 1.415 5.02 5.02-5.02 5.021 1.414 1.414 5.021-5.02 5.02 5.02 1.414-1.414z"/><path d="M1 21l3.5-6.06A9 9 0 1 1 12 21H1z"/></svg>
          {{ section.settings.android_label | default: 'Get it on Google Play' }}
        </a>
      {%- endif -%}

      {%- if section.settings.apk_url != blank -%}
        <a class="app-download__btn app-download__btn--apk" href="{{ section.settings.apk_url }}" id="btn-apk" download>
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M19 9h-4V3H9v6H5l7 7 7-7zM5 18v2h14v-2H5z"/></svg>
          {{ section.settings.apk_label | default: 'Download APK (Android)' }}
        </a>
      {%- endif -%}
    </div>

    {%- if section.settings.show_auto_redirect -%}
      <p class="app-download__redirect-msg" id="app-redirect-msg">Detecting your device&hellip;</p>
    {%- endif -%}

  </div>
</div>

{%- if section.settings.show_auto_redirect -%}
<script>
  (function() {
    var ua = navigator.userAgent.toLowerCase();
    var msg = document.getElementById('app-redirect-msg');
    var chinaBrands = ['huawei','xiaomi','oppo','vivo','honor','realme','oneplus','meizu','lenovo','zte','coolpad'];
    var isChina = chinaBrands.some(function(b){ return ua.indexOf(b) !== -1; });
    var hasPlay = ua.indexOf('google') !== -1 || ua.indexOf('play') !== -1 || ua.indexOf('gms') !== -1;

    if (ua.indexOf('android') !== -1) {
      if (isChina && !hasPlay) {
        var apkUrl = {{ section.settings.apk_url | json }};
        if (apkUrl) { window.location.href = apkUrl; }
        if (msg) msg.textContent = 'Downloading APK\u2026';
      } else {
        var androidUrl = {{ section.settings.android_url | json }};
        if (androidUrl) { window.location.href = androidUrl; }
      }
    } else if (ua.indexOf('iphone') !== -1 || ua.indexOf('ipad') !== -1) {
      var iosUrl = {{ section.settings.ios_url | json }};
      if (iosUrl) { window.location.href = iosUrl; }
    } else {
      if (msg) msg.textContent = 'Choose your platform above.';
    }
  })();
</script>
{%- endif -%}

{% schema %}
{
  "name": "App Download",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Download the FlexTarget App" },
    { "type": "textarea", "id": "subtext", "label": "Subtext", "default": "Available on iOS and Android. Scan to download or choose your platform below." },
    { "type": "header", "content": "iOS" },
    { "type": "url", "id": "ios_url", "label": "App Store URL" },
    { "type": "text", "id": "ios_label", "label": "Button label", "default": "Download on App Store" },
    { "type": "header", "content": "Android" },
    { "type": "url", "id": "android_url", "label": "Google Play URL" },
    { "type": "text", "id": "android_label", "label": "Button label", "default": "Get it on Google Play" },
    { "type": "header", "content": "Direct APK" },
    { "type": "url", "id": "apk_url", "label": "APK file URL" },
    { "type": "text", "id": "apk_label", "label": "Button label", "default": "Download APK (Android)" },
    { "type": "header", "content": "Auto Redirect" },
    { "type": "checkbox", "id": "show_auto_redirect", "label": "Auto-redirect based on device", "default": true, "info": "Automatically sends iOS users to App Store, Android users to Play Store (or APK for China devices)." }
  ],
  "presets": [{ "name": "App Download" }]
}
{% endschema %}
